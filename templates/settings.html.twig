{% extends 'base.html.twig' %}

{% block title %}Settings — Claudriel{% endblock %}

{% block nav_actions %}
    <a href="/app" style="color: var(--text-secondary); text-decoration: none; font-size: 0.8rem;">Dashboard</a>
    <form method="post" action="/logout" style="margin: 0;">
        <button type="submit" class="nav-logout">Log out</button>
    </form>
{% endblock %}

{% block content %}
<div style="max-width: 640px; margin: 40px auto; padding: 0 20px;">
  <h1 style="font-family: var(--font-display); font-size: 24px; margin-bottom: 32px; color: var(--text-primary);">Settings</h1>

  <section style="background: var(--bg-surface); border: 1px solid var(--border); border-radius: 12px; padding: 24px; margin-bottom: 24px;">
    <h2 style="font-size: 16px; font-weight: 600; margin-bottom: 16px; color: var(--text-primary);">Connected Accounts</h2>

    <div style="display: flex; align-items: center; justify-content: space-between; padding: 16px; background: var(--bg-elevated); border-radius: 8px;">
      <div style="display: flex; align-items: center; gap: 12px;">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
        <div>
          <div style="font-weight: 500; color: var(--text-primary);">Google</div>
          {% if google_connected %}
            <div style="font-size: 13px; color: var(--text-secondary);">{{ google_email }}</div>
          {% else %}
            <div style="font-size: 13px; color: var(--text-muted);">Not connected</div>
          {% endif %}
        </div>
      </div>

      {% if google_connected %}
        <button id="google-disconnect-btn" onclick="confirmDisconnect('google')" style="padding: 8px 16px; background: transparent; border: 1px solid var(--accent-red); color: var(--accent-red); border-radius: 6px; cursor: pointer; font-size: 13px;">Disconnect</button>
      {% else %}
        <a href="/oauth/google/connect" style="padding: 8px 16px; background: var(--accent-blue); color: #fff; border-radius: 6px; text-decoration: none; font-size: 13px;">Connect</a>
      {% endif %}
    </div>

    <div style="display: flex; align-items: center; justify-content: space-between; padding: 16px; background: var(--bg-elevated); border-radius: 8px; margin-top: 8px;">
      <div style="display: flex; align-items: center; gap: 12px;">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        <div>
          <div style="font-weight: 500; color: var(--text-primary);">GitHub</div>
          {% if github_connected %}
            <div style="font-size: 13px; color: var(--text-secondary);">{{ github_username }}</div>
          {% else %}
            <div style="font-size: 13px; color: var(--text-muted);">Not connected</div>
          {% endif %}
        </div>
      </div>

      {% if github_connected %}
        <button id="github-disconnect-btn" onclick="confirmDisconnect('github')" style="padding: 8px 16px; background: transparent; border: 1px solid var(--accent-red); color: var(--accent-red); border-radius: 6px; cursor: pointer; font-size: 13px;">Disconnect</button>
      {% else %}
        <a href="/oauth/github/connect" style="padding: 8px 16px; background: #24292f; color: #fff; border-radius: 6px; text-decoration: none; font-size: 13px;">Connect</a>
      {% endif %}
    </div>
  </section>

  <section style="background: var(--bg-surface); border: 1px solid var(--border); border-radius: 12px; padding: 24px; margin-bottom: 24px;">
    <h2 style="font-size: 16px; font-weight: 600; margin-bottom: 16px; color: var(--text-primary);">Chat Turn Limits</h2>

    <form method="post" action="/api/settings/chat-turn-limits" style="margin-top: 8px;">
      <div style="display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 12px 16px; background: var(--bg-elevated); border-radius: 8px;">
        <label for="daily-turn-ceiling" style="font-size: 13px; color: var(--text-secondary); font-weight: 500;">Daily turn ceiling</label>
        <input
          id="daily-turn-ceiling"
          name="daily_turn_ceiling"
          type="number"
          min="1"
          step="1"
          value="{{ daily_turn_ceiling }}"
          data-testid="daily-turn-ceiling"
          style="width: 140px; padding: 8px 10px; border: 1px solid var(--border); border-radius: 6px; background: var(--bg-surface); color: var(--text-primary);"
          required
        />
      </div>

      <div style="display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12px; margin-top: 16px;">
        {% for taskType in ['quick_lookup','email_compose','brief_generation','research','general','onboarding'] %}
          <div style="display: flex; flex-direction: column; gap: 6px; padding: 14px 14px; background: var(--bg-elevated); border-radius: 8px;">
            <label for="turn-limit-{{ taskType }}" style="font-size: 13px; color: var(--text-secondary); font-weight: 500; text-transform: none;">
              {{ taskType }}
            </label>
            <input
              id="turn-limit-{{ taskType }}"
              name="turn_limits[{{ taskType }}]"
              type="number"
              min="1"
              step="1"
              value="{{ chat_turn_limits[taskType] ?? 0 }}"
              data-testid="turn-limit-{{ taskType }}"
              style="width: 100%; padding: 8px 10px; border: 1px solid var(--border); border-radius: 6px; background: var(--bg-surface); color: var(--text-primary);"
              required
            />
          </div>
        {% endfor %}
      </div>

      <button type="submit" style="margin-top: 18px; padding: 10px 16px; background: var(--accent-blue); border: none; color: #fff; border-radius: 8px; cursor: pointer; font-size: 14px; font-weight: 600;">
        Save Chat Turn Settings
      </button>
    </form>
  </section>

  <a href="/dashboard" style="color: var(--text-secondary); font-size: 14px; text-decoration: none;">&larr; Back to Dashboard</a>
</div>

<dialog id="confirm-dialog" style="background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 12px; padding: 24px; color: var(--text-primary); max-width: 400px;">
  <p id="confirm-message" style="margin-bottom: 16px;">Disconnect this account?</p>
  <div style="display: flex; gap: 12px; justify-content: flex-end;">
    <button onclick="document.getElementById('confirm-dialog').close()" style="padding: 8px 16px; background: var(--bg-hover); border: 1px solid var(--border); color: var(--text-secondary); border-radius: 6px; cursor: pointer;">Cancel</button>
    <button onclick="doDisconnect()" style="padding: 8px 16px; background: var(--accent-red); border: none; color: #fff; border-radius: 6px; cursor: pointer;">Disconnect</button>
  </div>
</dialog>

<script>
let disconnectProvider = null;
const messages = {
  google: 'This will stop email and calendar sync. Continue?',
  github: 'This will stop GitHub notifications and issue sync. Continue?'
};
function confirmDisconnect(provider) {
  disconnectProvider = provider;
  document.getElementById('confirm-message').textContent = messages[provider] || 'Disconnect this account?';
  document.getElementById('confirm-dialog').showModal();
}
async function doDisconnect() {
  document.getElementById('confirm-dialog').close();
  const btn = document.getElementById(disconnectProvider + '-disconnect-btn');
  btn.textContent = 'Disconnecting...';
  btn.disabled = true;
  try {
    const res = await fetch('/api/' + disconnectProvider + '/disconnect', { method: 'POST' });
    if (res.ok) { window.location.reload(); }
    else { btn.textContent = 'Error'; }
  } catch { btn.textContent = 'Error'; }
}
</script>
{% endblock %}
