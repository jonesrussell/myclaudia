{% extends "public/auth-layout.twig" %}

{% block auth_page_title %}Log In{% endblock %}

{% block auth_eyebrow %}Welcome back{% endblock %}
{% block auth_headline %}Your day is waiting.{% endblock %}
{% block auth_subtext %}Commitments, schedule, and context, right where you left them.{% endblock %}

{% block auth_form %}
    <h2>Log in</h2>

    {% if verified is defined and verified %}
        <div class="auth-success">Your email has been verified. Please log in to continue.</div>
    {% endif %}

    {% if error is defined and error %}
        <div class="auth-error">{{ error }}</div>
    {% endif %}

    <form method="post" action="/login">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
        {% if redirect is defined and redirect %}
            <input type="hidden" name="redirect" value="{{ redirect }}">
        {% endif %}

        <div class="auth-field">
            <label for="email">Email</label>
            <input id="email" type="email" name="email" value="{{ email|default('') }}" autocomplete="email" required>
        </div>

        <div class="auth-field">
            <label for="password">Password</label>
            <input id="password" type="password" name="password" autocomplete="current-password" required>
        </div>

        <div class="auth-forgot">
            <a href="/forgot-password">Forgot your password?</a>
        </div>

        <button type="submit" class="auth-submit">Log in</button>
    </form>
{% endblock %}

{% block auth_links %}
    Don't have an account? <a href="/signup">Join the waitlist</a>
{% endblock %}

{% block scripts %}
<script>
(function () {
    var h = new Date().getHours();
    var headline, subtext;
    if (h >= 5 && h < 12) {
        headline = "Your day is waiting.";
        subtext = "Commitments, schedule, and context, right where you left them.";
    } else if (h >= 12 && h < 17) {
        headline = "Pick up where you left off.";
        subtext = "Your schedule and commitments are still in play.";
    } else if (h >= 17 && h < 22) {
        headline = "Still in the arena.";
        subtext = "Everything\u2019s here when you need it.";
    } else {
        headline = "Burning the midnight oil?";
        subtext = "Your schedule and commitments don\u2019t sleep either.";
    }
    document.getElementById("auth-headline").textContent = headline;
    document.getElementById("auth-subtext").textContent = subtext;
})();
</script>
{% endblock %}
