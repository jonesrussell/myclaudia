{% extends "base.html.twig" %}

{% block title %}Create Your Account — Claudriel{% endblock %}

{% block styles %}
    .site-nav { background: transparent; border-bottom: 0; }
    body {
        min-height: 100vh;
        background:
            radial-gradient(circle at 50% 20%, rgba(107, 155, 255, 0.14), transparent 40%),
            radial-gradient(circle at 30% 70%, rgba(45, 212, 191, 0.08), transparent 30%),
            linear-gradient(180deg, #0a0c10 0%, #131620 52%, #0a0c10 100%);
    }
    .signup-shell {
        max-width: 680px;
        margin: 0 auto;
        padding: 4rem 1.4rem 3rem;
        text-align: center;
    }
    .signup-badge {
        display: inline-block;
        font-size: 0.72rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--accent-teal);
        border: 1px solid rgba(45, 212, 191, 0.25);
        border-radius: 999px;
        padding: 0.35rem 1rem;
        margin-bottom: 1.5rem;
    }
    .signup-shell h1 {
        font-family: var(--font-display);
        font-size: clamp(2.2rem, 5.5vw, 3.6rem);
        line-height: 1;
        letter-spacing: -0.035em;
        margin-bottom: 0.75rem;
    }
    .signup-shell .lead {
        font-size: 1.05rem;
        color: var(--text-secondary);
        max-width: 480px;
        margin: 0 auto 2rem;
    }
    .signup-form {
        display: grid;
        gap: 0.9rem;
        max-width: 480px;
        margin: 0 auto 1rem;
        text-align: left;
    }
    .signup-form label {
        display: block;
        font-size: 0.85rem;
        font-weight: 600;
        margin-bottom: 0.4rem;
        color: var(--text-secondary);
    }
    .signup-form input[type="text"],
    .signup-form input[type="email"],
    .signup-form input[type="password"] {
        width: 100%;
        padding: 0.85rem 1rem;
        border-radius: 0.65rem;
        border: 1px solid var(--border-emphasis);
        background: var(--bg-input);
        color: var(--text-primary);
        font-family: var(--font-body);
        font-size: 0.95rem;
        transition: border-color 0.15s;
    }
    .signup-form input[type="text"]:focus,
    .signup-form input[type="email"]:focus,
    .signup-form input[type="password"]:focus {
        outline: none;
        border-color: var(--accent-teal);
        box-shadow: 0 0 0 3px rgba(45, 212, 191, 0.12);
    }
    .signup-form input::placeholder {
        color: var(--text-muted);
    }
    .signup-form button {
        padding: 0.85rem 1.4rem;
        border: 0;
        border-radius: 0.65rem;
        font-weight: 600;
        font-family: var(--font-body);
        font-size: 0.95rem;
        cursor: pointer;
        background: linear-gradient(135deg, #f0b040 0%, #d46337 100%);
        color: #15120e;
        box-shadow: 0 12px 30px rgba(212, 99, 55, 0.2);
        transition: transform 0.18s;
        white-space: nowrap;
    }
    .signup-form button:hover { transform: translateY(-1px); }
    .signup-message {
        max-width: 480px;
        margin: 0 auto 2rem;
        padding: 0.85rem 1rem;
        border-radius: 0.65rem;
        font-size: 0.9rem;
    }
    .signup-message.error {
        background: rgba(239, 68, 68, 0.12);
        border: 1px solid rgba(239, 68, 68, 0.25);
        color: #fca5a5;
    }
    .feature-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
        margin-top: 3rem;
    }
    .feature-card {
        padding: 1.25rem;
        border-radius: 1rem;
        background: var(--bg-surface);
        border: 1px solid var(--border);
        text-align: left;
    }
    .feature-icon {
        width: 2.2rem;
        height: 2.2rem;
        border-radius: 0.6rem;
        background: rgba(240, 176, 64, 0.1);
        border: 1px solid rgba(240, 176, 64, 0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 0.9rem;
        color: var(--accent-amber);
        font-size: 1rem;
    }
    .feature-card h3 {
        font-family: var(--font-display);
        font-size: 1rem;
        margin-bottom: 0.4rem;
    }
    .feature-card p {
        font-size: 0.85rem;
        color: var(--text-secondary);
        line-height: 1.5;
    }
    .signup-login {
        margin-top: 2rem;
        font-size: 0.85rem;
        color: var(--text-secondary);
    }
    .signup-login a {
        color: var(--accent-teal);
        text-decoration: none;
    }
    .signup-login a:hover { text-decoration: underline; }
    .signup-google-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        max-width: 480px;
        margin: 0 auto;
        padding: 0.85rem 1rem;
        border-radius: 0.65rem;
        border: 1px solid var(--border-emphasis);
        background: rgba(255, 255, 255, 0.04);
        color: var(--text-primary);
        font-family: var(--font-body);
        font-size: 0.95rem;
        font-weight: 600;
        text-decoration: none;
        transition: background 0.15s, border-color 0.15s;
    }
    .signup-google-btn:hover {
        background: rgba(255, 255, 255, 0.08);
        border-color: var(--accent-teal);
    }
    .signup-divider {
        display: flex;
        align-items: center;
        gap: 1rem;
        max-width: 480px;
        margin: 1.2rem auto;
        color: var(--text-muted);
        font-size: 0.82rem;
    }
    .signup-divider::before,
    .signup-divider::after {
        content: "";
        flex: 1;
        height: 1px;
        background: var(--border);
    }
    @media (max-width: 640px) {
        .signup-shell { padding: 2.5rem 1rem 2rem; }
        .signup-form button { width: 100%; }
        .feature-grid { grid-template-columns: 1fr; }
    }
{% endblock %}

{% block content %}
    <main class="signup-shell">
        <div class="signup-badge">Public Signup</div>
        <h1>Create your account</h1>
        <p class="lead">Get into Claudriel directly. Set up your account, verify your email, and start organizing commitments, schedule, and context in one place.</p>

        {% if error %}
            <div class="signup-message error">{{ error }}</div>
        {% endif %}

        <a href="/oauth/google/signin" class="signup-google-btn">
            <svg viewBox="0 0 24 24" width="18" height="18" style="margin-right: 0.5rem;">
                <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/>
                <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
            Sign up with Google
        </a>

        <div class="signup-divider"><span>or continue with email</span></div>

        <form class="signup-form" method="post" action="/signup">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

            <div>
                <label for="name">Name</label>
                <input id="name" type="text" name="name" placeholder="Ada Lovelace" value="{{ name }}" autocomplete="name" required>
            </div>

            <div>
                <label for="email">Email</label>
                <input id="email" type="email" name="email" placeholder="you@email.com" value="{{ email }}" autocomplete="email" required>
            </div>

            <div>
                <label for="password">Password</label>
                <input id="password" type="password" name="password" placeholder="Choose a password" autocomplete="new-password" required>
            </div>

            <button type="submit">Create account</button>
        </form>

        <div class="feature-grid">
            <article class="feature-card">
                <div class="feature-icon">&#x2714;</div>
                <h3>Commitment tracking</h3>
                <p>Every email, meeting, and thread scanned for promises and deadlines. Nothing falls through.</p>
            </article>
            <article class="feature-card">
                <div class="feature-icon">&#x2600;</div>
                <h3>Schedule intelligence</h3>
                <p>A daily brief that tells you what matters, what's drifting, and where your next deep work window is.</p>
            </article>
            <article class="feature-card">
                <div class="feature-icon">&#x21C4;</div>
                <h3>Client context</h3>
                <p>Relationship history, project state, and conversation threads, all in one place, always current.</p>
            </article>
        </div>

        <div class="signup-login">
            Already have an account? <a href="/login">Log in</a>
        </div>
    </main>
{% endblock %}
