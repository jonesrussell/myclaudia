<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Create Your Claudriel Account</title>
    <style>
        :root {
            --bg: #f4efe6;
            --panel: #fffaf2;
            --ink: #1c1a17;
            --muted: #6f6559;
            --accent: #ad4d2f;
            --accent-soft: #ead1c8;
            --border: rgba(28, 26, 23, 0.12);
        }
        body { margin: 0; font-family: Georgia, "Times New Roman", serif; background: radial-gradient(circle at top, #fff7eb, var(--bg)); color: var(--ink); }
        .shell { min-height: 100vh; display: grid; place-items: center; padding: 2rem; }
        .panel { width: min(32rem, 100%); background: var(--panel); border: 1px solid var(--border); border-radius: 1.5rem; padding: 2rem; box-shadow: 0 1.5rem 4rem rgba(28, 26, 23, 0.08); }
        h1 { margin: 0 0 0.75rem; font-size: clamp(2rem, 4vw, 3rem); line-height: 0.95; }
        p { color: var(--muted); line-height: 1.5; }
        form { display: grid; gap: 1rem; margin-top: 1.5rem; }
        label { display: grid; gap: 0.35rem; font-size: 0.95rem; }
        input { border: 1px solid var(--border); border-radius: 0.9rem; padding: 0.95rem 1rem; font: inherit; background: white; }
        button { border: 0; border-radius: 999px; padding: 0.95rem 1.2rem; background: var(--accent); color: white; font: inherit; cursor: pointer; }
        .error { background: var(--accent-soft); color: #6e2615; border-radius: 0.9rem; padding: 0.9rem 1rem; }
    </style>
</head>
<body>
    <main class="shell">
        <section class="panel">
            <p>Create an account</p>
            <h1>Bring your schedule into focus.</h1>
            <p>Use email and password to start your Claudriel account. We will send a verification link before onboarding continues.</p>
            {% if error %}
                <div class="error">{{ error }}</div>
            {% endif %}
            <form method="post" action="/signup">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                <label>
                    Name
                    <input type="text" name="name" value="{{ name }}" autocomplete="name" required>
                </label>
                <label>
                    Email
                    <input type="email" name="email" value="{{ email }}" autocomplete="email" required>
                </label>
                <label>
                    Password
                    <input type="password" name="password" autocomplete="new-password" required>
                </label>
                <button type="submit">Create account</button>
            </form>
        </section>
    </main>
</body>
</html>
