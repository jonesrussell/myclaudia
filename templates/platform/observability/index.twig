{% extends "base.html.twig" %}
{% macro call_chain_node(node, depth) %}
  <details class="call-chain-node depth-{{ depth }}{% if node.children is empty %} is-leaf{% endif %}" {% if node.expanded %}open{% endif %}>
    <summary>
      <span class="call-chain-status {{ node.status }}">{{ node.status }}</span>
      <span class="call-chain-copy">
        <span class="call-chain-title">{{ node.title }}</span>
        <span class="call-chain-summary">{{ node.summary }}</span>
      </span>
    </summary>
    {% if node.children is not empty %}
      <div class="call-chain-children">
        {% for child in node.children %}
          {{ _self.call_chain_node(child, depth + 1) }}
        {% endfor %}
      </div>
    {% endif %}
  </details>
{% endmacro %}

{% block title %}Platform Observability Dashboard{% endblock %}

{% block styles %}
  .observability-page {
    max-width: 1220px;
    margin: 0 auto;
    padding: 2rem 1.25rem 3rem;
  }
  .panel, .metric-card {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
  }
  .panel {
    padding: 1rem 1.1rem;
    margin-top: 1rem;
  }
  .hero h1, .panel h2 {
    font-family: var(--font-display);
  }
  .hero p, .muted {
    color: var(--text-secondary);
  }
  .nav-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 0.7rem 0.95rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-emphasis);
    color: var(--accent-blue);
    background: var(--bg-elevated);
    text-decoration: none;
    font-weight: 700;
  }
  .metric-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 0.85rem;
    margin-top: 1rem;
  }
  .metric-card {
    padding: 0.95rem 1rem;
  }
  .call-chain-panel {
    padding: 1.15rem 1.1rem 1.2rem;
  }
  .call-chain-header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: flex-start;
  }
  .call-chain-header h2 {
    margin-bottom: 0.35rem;
  }
  .call-chain-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }
  .call-chain-status {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 78px;
    padding: 0.22rem 0.55rem;
    border-radius: 999px;
    font-weight: 700;
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border: 1px solid transparent;
  }
  .call-chain-status.success {
    color: #ccf3dd;
    background: rgba(26, 122, 73, 0.18);
    border-color: rgba(87, 199, 138, 0.28);
  }
  .call-chain-status.fallback {
    color: #dce9ff;
    background: rgba(37, 91, 165, 0.18);
    border-color: rgba(107, 155, 255, 0.26);
  }
  .call-chain-status.retry {
    color: #ffe2b3;
    background: rgba(177, 110, 16, 0.18);
    border-color: rgba(241, 180, 78, 0.28);
  }
  .call-chain-status.error {
    color: #ffd0d0;
    background: rgba(181, 52, 52, 0.18);
    border-color: rgba(240, 96, 96, 0.32);
  }
  .call-chain-tree {
    margin-top: 1rem;
    border-left: 1px solid rgba(124, 196, 255, 0.14);
    padding-left: 1rem;
  }
  .call-chain-node {
    position: relative;
    margin-top: 0.75rem;
    border: 1px solid rgba(124, 196, 255, 0.08);
    border-radius: var(--radius-md);
    background: rgba(17, 22, 31, 0.72);
  }
  .call-chain-node::before {
    content: '';
    position: absolute;
    left: -1.25rem;
    top: 1.05rem;
    width: 0.7rem;
    height: 1px;
    background: rgba(124, 196, 255, 0.18);
  }
  .call-chain-node summary {
    list-style: none;
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    padding: 0.85rem 0.95rem;
    cursor: pointer;
  }
  .call-chain-node summary::-webkit-details-marker {
    display: none;
  }
  .call-chain-copy {
    display: flex;
    flex-direction: column;
    gap: 0.18rem;
  }
  .call-chain-title {
    font-weight: 700;
  }
  .call-chain-summary {
    color: var(--text-secondary);
    font-size: 0.82rem;
  }
  .call-chain-children {
    padding: 0 0.9rem 0.85rem 1rem;
    margin-left: 1rem;
    border-left: 1px dashed rgba(124, 196, 255, 0.12);
  }
  .call-chain-node.depth-0 {
    background: linear-gradient(180deg, rgba(31, 40, 58, 0.96) 0%, rgba(18, 23, 34, 0.96) 100%);
    border-color: rgba(124, 196, 255, 0.18);
  }
  .call-chain-node.is-leaf summary {
    cursor: default;
  }
  .metric-label {
    color: var(--text-secondary);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .metric-value {
    margin-top: 0.35rem;
    font-family: var(--font-display);
    font-size: 1.55rem;
  }
  .two-column {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  table {
    width: 100%;
    border-collapse: collapse;
  }
  th, td {
    padding: 0.7rem 0.6rem;
    text-align: left;
    border-bottom: 1px solid var(--border-subtle);
    vertical-align: top;
  }
  th {
    color: var(--text-secondary);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .severity-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 78px;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.74rem;
    letter-spacing: 0.05em;
  }
  .severity-pill.high, .severity-pill.critical {
    color: #ffd0d0;
    background: rgba(181, 52, 52, 0.18);
    border: 1px solid rgba(240, 96, 96, 0.32);
  }
  .severity-pill.medium, .severity-pill.warning {
    color: #ffe2b3;
    background: rgba(177, 110, 16, 0.18);
    border: 1px solid rgba(241, 180, 78, 0.28);
  }
  .severity-pill.low, .severity-pill.info {
    color: #ccf3dd;
    background: rgba(26, 122, 73, 0.18);
    border: 1px solid rgba(87, 199, 138, 0.28);
  }
  ul {
    margin: 0;
    padding-left: 1.2rem;
  }
  li + li {
    margin-top: 0.45rem;
  }
  @media (max-width: 900px) {
    .two-column {
      grid-template-columns: 1fr;
    }
    .call-chain-header {
      flex-direction: column;
    }
  }
{% endblock %}

{% block content %}
  <main class="observability-page">
    {% include 'components/status-bar.twig' with { data: statusBarData } %}
    <section class="hero">
      <p><a class="nav-link" href="/audit/commitment-extraction">Back to audit dashboard</a></p>
      <h1>Platform Observability Dashboard</h1>
      <p class="muted">{{ system_summary }}</p>
    </section>

    <section class="panel call-chain-panel">
      <div class="call-chain-header">
        <div>
          <h2>Observability Call Chain</h2>
          <p class="muted">Hierarchical view of the product observability scan, with expandable nodes and explicit execution states.</p>
        </div>
        <div class="call-chain-legend" aria-label="Call chain status legend">
          {% for item in call_chain.legend %}
            <span class="call-chain-status {{ item.status }}">{{ item.label }}</span>
          {% endfor %}
        </div>
      </div>
      <div class="call-chain-tree" aria-label="Observability call chain">
        {{ _self.call_chain_node(call_chain.root, 0) }}
      </div>
    </section>

    <section class="panel">
      <h2>Extraction Health</h2>
      <div class="metric-grid">
        <article class="metric-card">
          <div class="metric-label">Avg confidence</div>
          <div class="metric-value">{{ extraction_health.average_confidence }}</div>
        </article>
        <article class="metric-card">
          <div class="metric-label">Low-confidence rate</div>
          <div class="metric-value">{{ (extraction_health.low_confidence_rate * 100)|round(1) }}%</div>
        </article>
        <article class="metric-card">
          <div class="metric-label">Attempts</div>
          <div class="metric-value">{{ extraction_health.summary_metrics.total_extraction_attempts }}</div>
        </article>
      </div>
      <table>
        <thead>
          <tr>
            <th>Top failure categories</th>
            <th>Count</th>
            <th>Rate</th>
          </tr>
        </thead>
        <tbody>
          {% for category in extraction_health.top_failure_categories %}
            <tr>
              <td><code>{{ category.category }}</code></td>
              <td>{{ category.count }}</td>
              <td>{{ (category.rate * 100)|round(1) }}%</td>
            </tr>
          {% else %}
            <tr>
              <td colspan="3">No failure categories recorded.</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </section>

    <section class="panel">
      <h2>Drift Overview</h2>
      <div class="metric-grid">
        <article class="metric-card">
          <div class="metric-label">Classification</div>
          <div class="metric-value">{{ drift_overview.classification }}</div>
        </article>
        <article class="metric-card">
          <div class="metric-label">Avg delta</div>
          <div class="metric-value">{{ drift_overview.delta.avg_confidence_delta > 0 ? '+' : '' }}{{ (drift_overview.delta.avg_confidence_delta * 100)|round(1) }}%</div>
        </article>
        <article class="metric-card">
          <div class="metric-label">Low-rate delta</div>
          <div class="metric-value">{{ drift_overview.delta.low_confidence_rate_delta > 0 ? '+' : '' }}{{ (drift_overview.delta.low_confidence_rate_delta * 100)|round(1) }}%</div>
        </article>
      </div>
    </section>

    <section class="panel">
      <h2>Self-Assessment</h2>
      <div class="metric-grid">
        <article class="metric-card">
          <div class="metric-label">Overall score</div>
          <div class="metric-value">{{ self_assessment.overall_score }}/100</div>
        </article>
        <article class="metric-card">
          <div class="metric-label">Top hotspot</div>
          <div class="metric-value">{{ self_assessment.sender_hotspots[0].sender|default('None') }}</div>
        </article>
      </div>
      <div class="two-column">
        <div>
          <h3>Hotspots</h3>
          <ul>
            {% for hotspot in self_assessment.sender_hotspots %}
              <li>{{ hotspot.sender }} ({{ hotspot.classification }})</li>
            {% else %}
              <li>No sender hotspots detected.</li>
            {% endfor %}
          </ul>
        </div>
        <div>
          <h3>Focus Areas</h3>
          <ul>
            {% for area in self_assessment.recommended_focus_areas %}
              <li>{{ area }}</li>
            {% else %}
              <li>No active focus areas.</li>
            {% endfor %}
          </ul>
        </div>
      </div>
    </section>

    <section class="panel">
      <h2>Improvement Suggestions</h2>
      <table>
        <thead>
          <tr>
            <th>Category</th>
            <th>Severity</th>
            <th>Recommended action</th>
          </tr>
        </thead>
        <tbody>
          {% for suggestion in improvement_suggestions %}
            <tr>
              <td><code>{{ suggestion.category }}</code></td>
              <td><span class="severity-pill {{ suggestion.severity }}">{{ suggestion.severity }}</span></td>
              <td>{{ suggestion.recommended_action }}</td>
            </tr>
          {% else %}
            <tr>
              <td colspan="3">No suggestions generated.</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </section>

    <section class="panel">
      <h2>Training Export Readiness</h2>
      <div class="metric-grid">
        <article class="metric-card">
          <div class="metric-label">Daily samples</div>
          <div class="metric-value">{{ training_export_readiness.daily_sample_count }}</div>
        </article>
        <article class="metric-card">
          <div class="metric-label">Failure samples</div>
          <div class="metric-value">{{ training_export_readiness.failure_sample_count }}</div>
        </article>
      </div>
      <table>
        <thead>
          <tr>
            <th>Failure category</th>
            <th>Count</th>
            <th>Rate</th>
          </tr>
        </thead>
        <tbody>
          {% for category in training_export_readiness.failure_distribution %}
            <tr>
              <td><code>{{ category.category }}</code></td>
              <td>{{ category.count }}</td>
              <td>{{ (category.rate * 100)|round(1) }}%</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </section>

    <section class="panel">
      <h2>Governance Integrity</h2>
      <p class="muted">{{ governance_integrity.summary }}</p>
      <table>
        <thead>
          <tr>
            <th>Issue</th>
            <th>Severity</th>
            <th>Context</th>
          </tr>
        </thead>
        <tbody>
          {% for issue in governance_integrity.issues %}
            <tr>
              <td><code>{{ issue.code }}</code></td>
              <td><span class="severity-pill {{ governance_integrity.classifications[issue.code]|default('info') }}">{{ governance_integrity.classifications[issue.code]|default('info') }}</span></td>
              <td>{{ issue.context }}</td>
            </tr>
          {% else %}
            <tr>
              <td colspan="3">No governance issues detected.</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </section>

    <section class="panel">
      <h2>Model Update Batches</h2>
      <table>
        <thead>
          <tr>
            <th>Batch ID</th>
            <th>Generated</th>
            <th>Samples</th>
            <th>Drift</th>
          </tr>
        </thead>
        <tbody>
          {% for batch in model_update_batches %}
            <tr>
              <td><a href="/ai/model-update-batch/{{ batch.batch_id|url_encode }}.json">{{ batch.batch_id }}</a></td>
              <td>{{ batch.generated_at|default('n/a') }}</td>
              <td>{{ batch.total_samples|default('n/a') }}</td>
              <td>{{ batch.drift_classification|default('n/a') }}</td>
            </tr>
          {% else %}
            <tr>
              <td colspan="4">No stored model update batches available.</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </section>

    <section class="panel">
      <h2>System Summary</h2>
      <p class="muted">{{ system_summary }}</p>
    </section>
  </main>
{% endblock %}
