{% extends "base.html.twig" %}
{% set active_nav = 'brief' %}

{% block head_extras %}
    <meta name="csrf-token" content="{{ csrf_token }}">
{% endblock %}

{% block title %}Dashboard — Claudriel{% endblock %}

{% block styles %}
        .site-nav-inner {
            max-width: 100%;
            padding: 0;
        }
        body {
            margin: 0;
            padding: 0;
            height: 100vh;
            overflow: hidden;
        }

        /* Scrollbar */
        ::-webkit-scrollbar { width: 5px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--text-muted); }

        /* ── Layout ── */
        .dashboard {
            display: grid;
            grid-template-columns: 300px 1fr;
            height: calc(100vh - 3.25rem);
            transition: grid-template-columns 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .dashboard.panel-collapsed {
            grid-template-columns: 0px 1fr;
        }

        /* ── Context Panel ── */
        .context-panel {
            background: var(--bg-surface);
            border-right: 1px solid var(--border);
            overflow-y: auto;
            overflow-x: hidden;
            padding: 1.25rem 1.25rem;
            transition: opacity 0.3s ease, padding 0.3s ease;
        }
        .panel-collapsed .context-panel {
            opacity: 0;
            padding: 0;
            pointer-events: none;
            width: 0;
            overflow: hidden;
        }
        .panel-toggle {
            position: fixed;
            top: 3.75rem;
            left: 0;
            z-index: 100;
            background: var(--bg-elevated);
            color: var(--text-secondary);
            border: 1px solid var(--border);
            border-left: none;
            width: 24px;
            height: 32px;
            border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
            cursor: pointer;
            font-size: 0.7rem;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: left 0.3s cubic-bezier(0.4, 0, 0.2, 1), color 0.2s;
        }
        .panel-toggle:hover { color: var(--text-primary); }
        .dashboard:not(.panel-collapsed) .panel-toggle {
            left: 300px;
        }
        .panel-section {
            margin-bottom: 1.5rem;
        }
        .panel-section-title {
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: var(--text-muted);
            margin-bottom: 0.6rem;
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }
        .panel-section-title .badge {
            background: var(--bg-hover);
            color: var(--text-secondary);
            font-size: 0.65rem;
            padding: 0.1rem 0.45rem;
            border-radius: 10px;
            font-weight: 500;
        }

        /* Counter cards */
        .counter-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.5rem;
        }
        .counter-card {
            background: var(--bg-elevated);
            border-radius: var(--radius-md);
            padding: 0.6rem 0.5rem;
            text-align: center;
            cursor: pointer;
            transition: background 0.2s, transform 0.15s;
            border: 1px solid var(--border-subtle);
        }
        .counter-card:hover {
            background: var(--bg-hover);
            transform: translateY(-1px);
        }
        .counter-card .counter-value {
            font-family: var(--font-display);
            font-size: 1.5rem;
            font-weight: 700;
            line-height: 1.2;
        }
        .counter-card .counter-label {
            font-size: 0.68rem;
            color: var(--text-muted);
            letter-spacing: 0.02em;
        }
        .counter-card.job_hunt .counter-value { color: var(--accent-teal); }
        .counter-card.messages .counter-value { color: var(--accent-amber); }
        .counter-card.due_today .counter-value { color: var(--accent-red); }
        .counter-card.drifting .counter-value { color: #f87171; }

        /* Workspace cards */
        .workspace-card {
            background: var(--bg-elevated);
            border-radius: var(--radius-md);
            padding: 0.6rem 0.5rem;
            text-align: center;
            cursor: pointer;
            transition: background 0.2s, transform 0.22s ease, border-color 0.2s, opacity 0.22s ease, box-shadow 0.22s ease;
            border: 2px solid var(--border-subtle);
            opacity: 1;
            transform: translateY(0) scale(1);
        }
        .workspace-card:hover {
            background: var(--bg-hover);
            transform: translateY(-1px);
        }
        .workspace-card.selected {
            border-color: var(--accent-teal);
            background: rgba(45, 212, 191, 0.08);
        }
        .workspace-card .workspace-name {
            font-family: var(--font-display);
            font-size: 0.85rem;
            font-weight: 600;
            line-height: 1.3;
        }
        .workspace-card .workspace-activity {
            font-size: 0.68rem;
            color: var(--text-muted);
            letter-spacing: 0.02em;
        }
        .workspace-card.workspace-card-enter {
            opacity: 0;
            transform: translateY(14px) scale(0.96);
            box-shadow: 0 0 0 rgba(0, 0, 0, 0);
        }
        .workspace-card.workspace-card-enter-active {
            opacity: 1;
            transform: translateY(0) scale(1);
            box-shadow: 0 12px 24px rgba(45, 212, 191, 0.12);
        }
        .workspace-card.workspace-card-exit-active {
            opacity: 0;
            transform: translateY(-10px) scale(0.96);
            box-shadow: 0 0 0 rgba(0, 0, 0, 0);
            pointer-events: none;
        }
        .workspace-card.workspace-card-refresh {
            box-shadow: 0 0 0 1px rgba(107, 155, 255, 0.25), 0 10px 20px rgba(107, 155, 255, 0.12);
        }
        #workspaceCount.workspace-count-pulse {
            animation: workspaceBadgePulse 0.45s ease;
        }
        @keyframes workspaceBadgePulse {
            0% { transform: scale(1); }
            35% { transform: scale(1.18); }
            100% { transform: scale(1); }
        }
        .panel-item.drifting {
            border-left-color: var(--accent-red) !important;
        }
        .drifting-label {
            color: var(--accent-red);
            font-size: 0.7rem;
            font-weight: 500;
        }

        /* Panel items */
        .panel-item {
            padding: 0.45rem 0.65rem;
            margin-bottom: 0.35rem;
            background: var(--bg-elevated);
            border-radius: var(--radius-sm);
            font-size: 0.82rem;
            border-left: 3px solid var(--border);
            cursor: pointer;
            transition: background 0.15s;
        }
        .panel-item:hover {
            background: var(--bg-hover);
        }
        .panel-item .item-meta {
            display: block;
            font-size: 0.72rem;
            color: var(--text-muted);
            margin-top: 0.15rem;
        }
        .panel-item.schedule { border-left-color: var(--accent-blue); }
        .panel-item.job_hunt { border-left-color: var(--accent-teal); }
        .panel-item.people { border-left-color: var(--accent-amber); }
        .panel-item.triage { border-left-color: var(--accent-purple, #a78bfa); }
        .panel-item.commitment { border-left-color: var(--accent-red); }
        .panel-item.notification { border-left-color: var(--text-muted); }

        .panel-empty {
            color: var(--text-muted);
            font-style: italic;
            font-size: 0.82rem;
            padding: 0.25rem 0;
        }
        .schedule-timeline {
            position: relative;
            padding-left: 1.1rem;
            border-left: 1px solid rgba(107, 155, 255, 0.18);
        }
        .schedule-now-indicator {
            display: flex;
            align-items: center;
            gap: 0.45rem;
            margin: 0 0 0.75rem -1.1rem;
            color: var(--accent-blue);
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 0.05em;
            text-transform: uppercase;
        }
        .schedule-now-indicator::before {
            content: '';
            width: 0.7rem;
            height: 0.7rem;
            border-radius: 999px;
            background: var(--accent-blue);
            box-shadow: 0 0 0 4px rgba(107, 155, 255, 0.14);
        }
        .guidance-panel {
            display: grid;
            gap: 0.65rem;
        }
        .guidance-card {
            border: 1px solid rgba(45, 212, 191, 0.16);
            background: linear-gradient(180deg, rgba(45, 212, 191, 0.12), rgba(8, 15, 28, 0.82));
            border-radius: var(--radius-md);
            padding: 0.85rem 0.95rem;
            box-shadow: 0 14px 30px rgba(4, 10, 24, 0.26);
        }
        .guidance-card[data-agent-name="overrun-alert"] {
            border-color: rgba(239, 68, 68, 0.28);
            background: linear-gradient(180deg, rgba(239, 68, 68, 0.12), rgba(26, 10, 14, 0.92));
        }
        .guidance-card[data-agent-name="shift-risk"] {
            border-color: rgba(232, 168, 56, 0.26);
            background: linear-gradient(180deg, rgba(232, 168, 56, 0.12), rgba(26, 19, 10, 0.92));
        }
        .guidance-card-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 0.65rem;
        }
        .guidance-card-title {
            font-family: var(--font-display);
            font-size: 0.88rem;
            font-weight: 600;
            color: var(--text-primary);
        }
        .guidance-card-chip {
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
            border-radius: 999px;
            padding: 0.2rem 0.55rem;
            font-size: 0.66rem;
            letter-spacing: 0.05em;
            text-transform: uppercase;
            color: var(--text-secondary);
            background: rgba(255, 255, 255, 0.06);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }
        .guidance-card-summary {
            margin-top: 0.45rem;
            font-size: 0.78rem;
            line-height: 1.45;
            color: var(--text-secondary);
        }
        .guidance-card-actions,
        .ambient-nudge-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 0.45rem;
            margin-top: 0.75rem;
        }
        .guidance-button {
            border: 1px solid rgba(107, 155, 255, 0.22);
            background: rgba(107, 155, 255, 0.1);
            color: var(--text-primary);
            border-radius: 999px;
            padding: 0.34rem 0.7rem;
            font-size: 0.72rem;
            font-family: var(--font-body);
            cursor: pointer;
            transition: transform 0.15s ease, background 0.15s ease, border-color 0.15s ease;
        }
        .guidance-button:hover {
            transform: translateY(-1px);
            background: rgba(107, 155, 255, 0.18);
            border-color: rgba(107, 155, 255, 0.35);
        }
        .guidance-button:disabled {
            opacity: 0.66;
            cursor: wait;
            transform: none;
        }
        .guidance-button--primary {
            background: rgba(45, 212, 191, 0.14);
            border-color: rgba(45, 212, 191, 0.28);
        }
        .guidance-meta {
            margin-top: 0.5rem;
            font-size: 0.68rem;
            color: var(--text-muted);
            letter-spacing: 0.03em;
        }
        .guidance-status {
            margin-top: 0.55rem;
            min-height: 1.1rem;
            font-size: 0.68rem;
            color: var(--text-muted);
        }
        .guidance-status[data-state="working"] { color: var(--accent-blue); }
        .guidance-status[data-state="complete"] { color: var(--accent-teal); }
        .guidance-status[data-state="error"] { color: var(--accent-red); }
        .ambient-nudge {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 0.85rem;
            margin-bottom: 0.85rem;
            padding: 0.85rem 0.95rem;
            border-radius: var(--radius-md);
            border: 1px solid rgba(107, 155, 255, 0.24);
            background: linear-gradient(120deg, rgba(38, 60, 101, 0.4), rgba(14, 22, 36, 0.95));
        }
        .ambient-nudge-copy {
            flex: 1;
            min-width: 0;
        }
        .ambient-nudge-eyebrow {
            font-size: 0.66rem;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: var(--accent-blue);
        }
        .ambient-nudge-title {
            margin-top: 0.3rem;
            font-weight: 600;
            color: var(--text-primary);
        }
        .ambient-nudge-summary {
            margin-top: 0.22rem;
            font-size: 0.75rem;
            color: var(--text-secondary);
            line-height: 1.4;
        }
        .timeline-event {
            position: relative;
            margin-bottom: 0.65rem;
            padding: 0.75rem 0.85rem 0.75rem 1rem;
            border-radius: var(--radius-md);
            border: 1px solid var(--border-subtle);
            background: rgba(21, 28, 42, 0.72);
            transition: transform 0.18s ease, background 0.18s ease, opacity 0.18s ease, border-color 0.18s ease;
        }
        .timeline-event::before {
            content: '';
            position: absolute;
            left: -1.48rem;
            top: 1rem;
            width: 0.65rem;
            height: 0.65rem;
            border-radius: 999px;
            background: rgba(107, 155, 255, 0.6);
            border: 2px solid var(--bg-surface);
        }
        .timeline-event:hover {
            transform: translateY(-1px);
            background: rgba(28, 37, 56, 0.92);
        }
        .timeline-event--past {
            opacity: 0.52;
            background: rgba(21, 28, 42, 0.4);
        }
        .timeline-event--current {
            border-color: rgba(107, 155, 255, 0.55);
            background: rgba(38, 60, 101, 0.46);
            box-shadow: 0 12px 26px rgba(34, 82, 162, 0.18);
        }
        .timeline-event--current::before {
            background: var(--accent-blue);
            box-shadow: 0 0 0 4px rgba(107, 155, 255, 0.18);
        }
        .timeline-event--future .timeline-event-body {
            display: none;
        }
        .timeline-event--future:hover .timeline-event-body,
        .timeline-event--future.is-expanded .timeline-event-body {
            display: block;
        }
        .timeline-event-head {
            display: flex;
            align-items: baseline;
            justify-content: space-between;
            gap: 0.75rem;
        }
        .timeline-event-title {
            font-weight: 600;
            color: var(--text-primary);
        }
        .timeline-event-time {
            color: var(--text-secondary);
            font-size: 0.74rem;
            white-space: nowrap;
        }
        .timeline-event-body {
            margin-top: 0.45rem;
            color: var(--text-secondary);
            font-size: 0.76rem;
        }
        .timeline-event-state {
            display: inline-flex;
            margin-top: 0.45rem;
            font-size: 0.68rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--text-muted);
        }
        .timeline-event-state.current { color: var(--accent-blue); }
        .timeline-event-state.future { color: var(--accent-teal); }
        .timeline-event-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 0.45rem;
            margin-top: 0.7rem;
        }
        .timeline-event-action {
            border: 1px solid rgba(107, 155, 255, 0.2);
            background: rgba(107, 155, 255, 0.08);
            color: var(--text-primary);
            border-radius: 999px;
            padding: 0.32rem 0.68rem;
            font-size: 0.72rem;
            font-family: var(--font-body);
            cursor: pointer;
            transition: background 0.16s ease, border-color 0.16s ease, transform 0.16s ease, opacity 0.16s ease;
        }
        .timeline-event-action:hover {
            background: rgba(107, 155, 255, 0.16);
            border-color: rgba(107, 155, 255, 0.35);
            transform: translateY(-1px);
        }
        .timeline-event-action:disabled {
            cursor: wait;
            opacity: 0.7;
            transform: none;
        }
        .timeline-event-action--primary {
            background: rgba(45, 212, 191, 0.12);
            border-color: rgba(45, 212, 191, 0.26);
        }
        .timeline-event-action--primary:hover {
            background: rgba(45, 212, 191, 0.2);
            border-color: rgba(45, 212, 191, 0.38);
        }
        .timeline-event-action-status {
            display: inline-flex;
            align-items: center;
            min-height: 1.3rem;
            margin-top: 0.55rem;
            font-size: 0.68rem;
            letter-spacing: 0.03em;
            color: var(--text-muted);
        }
        .timeline-event-action-status[data-state="pending"] {
            color: var(--accent-blue);
        }
        .timeline-event-action-status[data-state="success"] {
            color: var(--accent-teal);
        }
        .timeline-event-action-status[data-state="error"] {
            color: var(--accent-red);
        }
        .timeline-event.is-action-pending {
            border-color: rgba(107, 155, 255, 0.4);
            box-shadow: 0 0 0 1px rgba(107, 155, 255, 0.2);
        }

        /* ── Chat Area ── */
        .chat-area {
            display: flex;
            flex-direction: column;
            height: 100%;
            overflow: hidden;
            background: var(--bg-deep);
        }
        .chat-header {
            padding: 0.75rem 1.25rem;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: var(--bg-surface);
            flex-shrink: 0;
        }
        .chat-header h1 {
            font-family: var(--font-display);
            font-size: 1.1rem;
            font-weight: 600;
            letter-spacing: -0.02em;
        }
        .chat-model-badge {
            font-size: 0.65rem;
            font-weight: 500;
            color: var(--text-muted);
            background: var(--bg-hover);
            padding: 0.15rem 0.5rem;
            border-radius: 10px;
            margin-left: 0.5rem;
            border: 1px solid var(--border-subtle);
        }
        .chat-header-actions {
            display: flex;
            gap: 0.5rem;
            align-items: center;
        }
        .sessions-dropdown {
            position: relative;
        }
        .sessions-dropdown summary {
            cursor: pointer;
            font-size: 0.8rem;
            color: var(--text-secondary);
            list-style: none;
            padding: 0.25rem 0.6rem;
            border-radius: var(--radius-sm);
            background: var(--bg-elevated);
            border: 1px solid var(--border-subtle);
            transition: background 0.15s;
        }
        .sessions-dropdown summary::-webkit-details-marker { display: none; }
        .sessions-dropdown summary:hover { background: var(--bg-hover); }
        .session-tabs {
            display: flex;
            gap: 0.55rem;
            padding: 0.7rem 1.25rem 0.8rem;
            border-bottom: 1px solid var(--border);
            background:
                linear-gradient(180deg, rgba(91, 141, 239, 0.08), rgba(91, 141, 239, 0)),
                var(--bg-surface);
            overflow-x: auto;
            scrollbar-width: thin;
            flex-shrink: 0;
        }
        .session-tab {
            border: 1px solid var(--border-subtle);
            background: var(--bg-elevated);
            color: var(--text-secondary);
            border-radius: 999px;
            padding: 0.42rem 0.8rem;
            font-family: var(--font-body);
            font-size: 0.78rem;
            cursor: pointer;
            transition: transform 0.15s, background 0.15s, color 0.15s, border-color 0.15s;
            white-space: nowrap;
            max-width: 240px;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .session-tab:hover {
            background: var(--bg-hover);
            color: var(--text-primary);
        }
        .session-tab.is-active {
            background: rgba(45, 212, 191, 0.14);
            border-color: rgba(45, 212, 191, 0.38);
            color: var(--text-primary);
            transform: translateY(-1px);
        }
        .session-tab.is-new {
            animation: session-tab-enter 0.38s ease;
        }
        @keyframes session-tab-enter {
            0% { opacity: 0; transform: translateY(10px) scale(0.96); }
            100% { opacity: 1; transform: translateY(0) scale(1); }
        }
        .session-list {
            position: absolute;
            right: 0;
            top: calc(100% + 4px);
            background: var(--bg-elevated);
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            box-shadow: 0 8px 24px rgba(0,0,0,0.4);
            list-style: none;
            padding: 0.4rem 0;
            z-index: 50;
            min-width: 200px;
        }
        .session-list li a {
            display: block;
            padding: 0.4rem 0.85rem;
            color: var(--text-secondary);
            text-decoration: none;
            font-size: 0.8rem;
            transition: background 0.1s, color 0.1s;
        }
        .session-list li a:hover {
            background: var(--bg-hover);
            color: var(--text-primary);
        }
        .new-chat-btn {
            font-size: 0.8rem;
            color: var(--accent-teal);
            text-decoration: none;
            padding: 0.25rem 0.6rem;
            border-radius: var(--radius-sm);
            background: rgba(45, 212, 191, 0.1);
            border: 1px solid rgba(45, 212, 191, 0.2);
            cursor: pointer;
            font-family: inherit;
            font-weight: 500;
            transition: background 0.15s;
        }
        .new-chat-btn:hover { background: rgba(45, 212, 191, 0.18); }

        .messages {
            flex: 1;
            overflow-y: auto;
            padding: 1.25rem 1.25rem;
        }
        .message {
            margin-bottom: 1rem;
            padding: 0.85rem 1.1rem;
            border-radius: var(--radius-md);
            font-size: 0.9rem;
            max-width: 80%;
        }
        .message.user {
            background: var(--accent-blue);
            color: #fff;
            margin-left: auto;
            border-bottom-right-radius: 3px;
        }
        .message.assistant {
            background: var(--bg-surface);
            border: 1px solid var(--border);
            border-bottom-left-radius: 3px;
        }
        .message.assistant .message-content {
            white-space: pre-wrap;
            word-wrap: break-word;
        }
        .message.assistant .message-content p { margin-bottom: 0.5rem; }
        .message.assistant .message-content p:last-child { margin-bottom: 0; }
        .message-progress {
            display: flex;
            flex-wrap: wrap;
            gap: 0.45rem;
            margin-bottom: 0.75rem;
        }
        .message-progress-item {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            opacity: 0;
            transform: translateY(6px) scale(0.98);
            padding: 0.35rem 0.55rem;
            border-radius: 999px;
            border: 1px solid rgba(91, 141, 239, 0.22);
            background: rgba(91, 141, 239, 0.08);
            color: var(--text-secondary);
            font-size: 0.72rem;
            transition: opacity 0.22s ease, transform 0.22s ease, border-color 0.2s ease, background 0.2s ease;
        }
        .message-progress-item.is-visible {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
        .message-progress-item.is-warning {
            border-color: rgba(232, 168, 56, 0.28);
            background: rgba(232, 168, 56, 0.12);
        }
        .message-progress-item.is-error {
            border-color: rgba(239, 68, 68, 0.28);
            background: rgba(239, 68, 68, 0.12);
        }
        .message-progress-item.is-success {
            border-color: rgba(45, 212, 191, 0.3);
            background: rgba(45, 212, 191, 0.12);
        }
        .progress-phase {
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: var(--text-muted);
        }
        .progress-summary {
            color: var(--text-primary);
        }
        .message-label {
            font-size: 0.68rem;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            margin-bottom: 0.3rem;
            color: var(--text-muted);
        }
        .message.user .message-label { color: rgba(255,255,255,0.6); }

        /* Rich cards in chat */
        .chat-card {
            border-radius: var(--radius-md);
            padding: 0.75rem 1rem;
            margin: 0.5rem 0;
            border-left: 3px solid var(--border);
            background: var(--bg-elevated);
        }
        .chat-card-header {
            font-family: var(--font-display);
            font-weight: 600;
            font-size: 0.85rem;
            margin-bottom: 0.35rem;
        }
        .chat-card-body { font-size: 0.85rem; color: var(--text-secondary); }
        .chat-card-body ul { padding-left: 1.2rem; margin: 0.25rem 0; }
        .chat-card-body li { margin-bottom: 0.2rem; }
        .chat-card--schedule { border-left-color: var(--accent-blue); background: rgba(91, 141, 239, 0.08); }
        .chat-card--job-hunt { border-left-color: var(--accent-teal); background: rgba(45, 212, 191, 0.08); }
        .chat-card--people { border-left-color: var(--accent-amber); background: rgba(232, 168, 56, 0.08); }
        .chat-card--commitment { border-left-color: var(--accent-red); background: rgba(239, 68, 68, 0.08); }
        .chat-card--creator { border-left-color: var(--accent-purple); background: rgba(167, 139, 250, 0.08); }
        .chat-card--notification { border-left-color: var(--text-muted); background: var(--bg-hover); }

        /* ── Thinking Indicator ── */
        @keyframes shimmer {
            0% { background-position: -200% center; }
            100% { background-position: 200% center; }
        }
        .thinking-indicator .message-content {
            background: linear-gradient(90deg, var(--text-muted) 25%, var(--text-secondary) 50%, var(--text-muted) 75%);
            background-size: 200% auto;
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
            animation: shimmer 2s linear infinite;
            font-style: italic;
        }

        /* ── Streaming Cursor ── */
        @keyframes pulse-dot {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.2; }
        }
        .message.assistant.streaming .message-content::after {
            content: ' \25CF';
            animation: pulse-dot 1s ease-in-out infinite;
            font-size: 0.7em;
            color: var(--accent-blue);
        }

        .not-configured {
            background: rgba(232, 168, 56, 0.1);
            border: 1px solid rgba(232, 168, 56, 0.3);
            padding: 0.75rem 1rem;
            border-radius: var(--radius-md);
            margin: 0.75rem 1.25rem;
            font-size: 0.9rem;
            color: var(--accent-amber);
        }
        .not-configured code {
            background: var(--bg-hover);
            padding: 0.1rem 0.35rem;
            border-radius: 3px;
            font-size: 0.85em;
        }
        .empty-state {
            color: var(--text-muted);
            font-style: italic;
            text-align: center;
            padding: 4rem 1rem;
        }
        .error-message {
            background: rgba(239, 68, 68, 0.1);
            border: 1px solid rgba(239, 68, 68, 0.25);
            color: #f87171;
            padding: 0.5rem 0.85rem;
            border-radius: var(--radius-sm);
            font-size: 0.85rem;
            margin-bottom: 0.5rem;
        }

        .input-area {
            padding: 0.85rem 1.25rem;
            border-top: 1px solid var(--border);
            display: flex;
            gap: 0.6rem;
            background: var(--bg-surface);
            flex-shrink: 0;
        }
        .input-area textarea {
            flex: 1;
            padding: 0.7rem 0.85rem;
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            font-family: var(--font-body);
            font-size: 0.9rem;
            resize: none;
            min-height: 42px;
            max-height: 120px;
            line-height: 1.4;
            background: var(--bg-elevated);
            color: var(--text-primary);
            transition: border-color 0.2s;
        }
        .input-area textarea::placeholder { color: var(--text-muted); }
        .input-area textarea:focus {
            outline: none;
            border-color: var(--accent-blue);
            box-shadow: 0 0 0 2px rgba(91, 141, 239, 0.15);
        }
        .input-area button {
            padding: 0 1.25rem;
            background: var(--accent-blue);
            color: #fff;
            border: none;
            border-radius: var(--radius-md);
            font-size: 0.85rem;
            font-weight: 500;
            cursor: pointer;
            white-space: nowrap;
            font-family: var(--font-body);
            transition: background 0.15s, transform 0.1s;
        }
        .input-area button:hover { background: #4a7de0; }
        .input-area button:active { transform: scale(0.98); }
        .input-area button:disabled {
            background: var(--bg-hover);
            color: var(--text-muted);
            cursor: not-allowed;
        }

        @media (max-width: 1024px) {
            .dashboard { grid-template-columns: 0px 1fr; }
            .dashboard .context-panel { opacity: 0; padding: 0; pointer-events: none; width: 0; overflow: hidden; }
            .dashboard:not(.panel-collapsed) .panel-toggle { left: 0; }
            .dashboard.panel-open { grid-template-columns: 280px 1fr; }
            .dashboard.panel-open .context-panel { opacity: 1; padding: 1.25rem 1.25rem; pointer-events: auto; width: auto; overflow-y: auto; }
            .dashboard.panel-open .panel-toggle { left: 280px; }
        }
{% endblock %}

{% block content %}
    <div class="dashboard" id="dashboard">
        <button class="panel-toggle" id="panelToggle" title="Toggle context panel">&laquo;</button>

        {# ── Context Panel ── #}
        <aside class="context-panel" id="contextPanel">
            {# Workspaces #}
            <div class="panel-section" id="panelWorkspaces">
                <div class="panel-section-title">Workspaces <span class="badge" id="workspaceCount">{{ workspaces|default([])|length }}</span></div>
                <div class="counter-grid" id="workspaceGrid">
                    {% if workspaces|default([])|length > 0 %}
                        {% for ws in workspaces|default([]) %}
                            <div class="workspace-card" data-workspace-uuid="{{ ws.uuid }}" data-workspace-name="{{ ws.name }}">
                                <div class="workspace-name">{{ ws.name }}</div>
                                <div class="workspace-activity">{{ ws.activity_count|default(0) }} events</div>
                            </div>
                        {% endfor %}
                    {% else %}
                        <div class="panel-empty" style="grid-column: 1/-1;">No workspaces yet.</div>
                    {% endif %}
                </div>
            </div>

            <div class="panel-section" id="panelGuidance">
                <div class="panel-section-title">Guidance <span class="badge" id="guidanceCount">{{ proactive_guidance.notifications|default([])|length }}</span></div>
                <div id="guidancePanel" class="guidance-panel">
                    {% if proactive_guidance.notifications|default([])|length > 0 %}
                        {% for notification in proactive_guidance.notifications|default([]) %}
                            {% set primary_action = notification.actions|default([])|length > 0 ? notification.actions|first : null %}
                            {% set primary_action_state = primary_action ? primary_action.state|default('idle') : 'idle' %}
                            {% set primary_action_status = primary_action_state == 'working'
                                ? 'Working…'
                                : (primary_action_state == 'complete'
                                    ? 'Complete'
                                    : (primary_action_state == 'failed' ? 'Action failed' : 'Ready')) %}
                            <article class="guidance-card" data-notification-uuid="{{ notification.uuid }}" data-agent-name="{{ notification.agent_name }}" data-workspace-uuid="{{ active_workspace_uuid|default('') }}">
                                <div class="guidance-card-header">
                                    <div>
                                        <div class="guidance-card-chip">{{ notification.agent_name|replace({'-': ' '})|title }}</div>
                                        <div class="guidance-card-title">{{ notification.title }}</div>
                                    </div>
                                </div>
                                <div class="guidance-card-summary">{{ notification.summary }}</div>
                                <div class="guidance-card-actions">
                                    {% if primary_action %}
                                        <button class="guidance-button guidance-button--primary" type="button" data-guidance-open="{{ primary_action.payload.prompt|default('') }}" data-guidance-notification="{{ notification.uuid }}" data-guidance-action="{{ primary_action.type }}">
                                            {{ primary_action.label }}
                                        </button>
                                    {% endif %}
                                    <button class="guidance-button" type="button" data-guidance-snooze="{{ notification.uuid }}" data-guidance-minutes="15">Snooze 15m</button>
                                    <button class="guidance-button" type="button" data-guidance-dismiss="{{ notification.uuid }}">Dismiss</button>
                                </div>
                                <div class="guidance-meta">{{ notification.reason_code|replace({'_': ' '})|title }}</div>
                                <div class="guidance-status" data-guidance-status="{{ primary_action_state }}" data-state="{{ primary_action_state }}">{{ primary_action_status }}</div>
                            </article>
                        {% endfor %}
                    {% else %}
                        <div class="panel-empty">No live guidance right now.</div>
                    {% endif %}
                </div>
            </div>

            {# Schedule #}
            <div class="panel-section" id="panelSchedule">
                {% set timeline = schedule_timeline|default(schedule) %}
                {% set now_ts = time_snapshot.local|date('U') %}
                <div class="panel-section-title">Schedule <span class="badge" id="scheduleCount">{{ timeline|length }}</span></div>
                <div id="scheduleItems">
                    {% if timeline|length > 0 %}
                        <div class="schedule-timeline">
                            {% if proactive_guidance.ambient_nudge %}
                                {% set nudge = proactive_guidance.ambient_nudge %}
                                <div class="ambient-nudge" data-notification-uuid="{{ nudge.uuid }}" data-workspace-uuid="{{ active_workspace_uuid|default('') }}">
                                    <div class="ambient-nudge-copy">
                                        <div class="ambient-nudge-eyebrow">Ambient Nudge</div>
                                        <div class="ambient-nudge-title">{{ nudge.title }}</div>
                                        <div class="ambient-nudge-summary">{{ nudge.summary }}</div>
                                    </div>
                                    <div class="ambient-nudge-actions">
                                        {% if nudge.actions|default([])|length > 0 %}
                                            {% set nudge_action = nudge.actions|first %}
                                            <button class="guidance-button guidance-button--primary" type="button" data-guidance-open="{{ nudge_action.payload.prompt|default('') }}" data-guidance-notification="{{ nudge.uuid }}" data-guidance-action="{{ nudge_action.type }}">
                                                {{ nudge_action.label }}
                                            </button>
                                        {% endif %}
                                    </div>
                                </div>
                            {% endif %}
                            <div class="schedule-now-indicator">Now · {{ time_snapshot.local|date('g:i A') }}</div>
                            {% for item in timeline %}
                                {% set start_ts = item.start_time|date('U') %}
                                {% set end_ts = item.end_time|date('U') %}
                                {% set state = end_ts <= now_ts ? 'past' : (start_ts <= now_ts and end_ts > now_ts ? 'current' : 'future') %}
                                <div class="timeline-event timeline-event--{{ state }}{% if state == 'future' and loop.first %} is-expanded{% endif %}" data-chat="Tell me about {{ item.title }}">
                                    <div class="timeline-event-head">
                                        <div class="timeline-event-title">{{ item.title }}</div>
                                        <div class="timeline-event-time">{{ item.start_time|date('g:i A') }}{% if item.end_time %} - {{ item.end_time|date('g:i A') }}{% endif %}</div>
                                    </div>
                                    <div class="timeline-event-body">
                                        <div>{{ item.source|default('manual')|replace({'-': ' '})|title }}</div>
                                        <div class="timeline-event-state {{ state }}">{{ state == 'current' ? 'Current block' : (state == 'future' ? 'Upcoming block' : 'Past block') }}</div>
                                        <div class="timeline-event-actions">
                                            <button class="timeline-event-action timeline-event-action--primary" type="button" data-schedule-action="{{ state == 'past'
                                                ? 'Capture follow-up actions from ' ~ item.title ~ ' at ' ~ item.start_time|date('g:i A') ~ (item.end_time ? ' through ' ~ item.end_time|date('g:i A') : '') ~ '.'
                                                : 'Prep me for ' ~ item.title ~ ' at ' ~ item.start_time|date('g:i A') ~ (item.end_time ? ' through ' ~ item.end_time|date('g:i A') : '') ~ '.'
                                            }}">
                                                {{ state == 'past' ? 'Capture follow-up' : 'Prep me' }}
                                            </button>
                                            <button class="timeline-event-action" type="button" data-schedule-action="{{ state == 'past'
                                                ? 'Summarize the outcome of ' ~ item.title ~ ' at ' ~ item.start_time|date('g:i A') ~ (item.end_time ? ' through ' ~ item.end_time|date('g:i A') : '') ~ '.'
                                                : (state == 'current'
                                                    ? 'Help me shift ' ~ item.title ~ ' at ' ~ item.start_time|date('g:i A') ~ (item.end_time ? ' through ' ~ item.end_time|date('g:i A') : '') ~ '.'
                                                    : 'Tell me about ' ~ item.title ~ ' at ' ~ item.start_time|date('g:i A') ~ (item.end_time ? ' through ' ~ item.end_time|date('g:i A') : '') ~ '.')
                                            }}">
                                                {{ state == 'past' ? 'Wrap-up' : (state == 'current' ? 'Shift plan' : 'Open in chat') }}
                                            </button>
                                        </div>
                                        <div class="timeline-event-action-status" data-state="idle">Ready</div>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="panel-empty">{{ schedule_summary|default('Your day is clear') }}</div>
                    {% endif %}
                </div>
            </div>

            {# Commitments (includes drifting) #}
            <div class="panel-section" id="panelCommitments">
                <div class="panel-section-title">Commitments <span class="badge" id="commitmentCount">{{ pending_commitments|length + drifting_commitments|length }}</span></div>
                <div id="commitmentItems">
                    {% if drifting_commitments|length > 0 %}
                        {% for c in drifting_commitments %}
                            <div class="panel-item commitment drifting" data-chat="What happened with {{ c.title }}?">
                                {{ c.title|default('(untitled)') }} <span class="drifting-label">(drifting)</span>
                                {% if c.updated_at %}<span class="item-meta">Last: {{ c.updated_at }}</span>{% endif %}
                            </div>
                        {% endfor %}
                    {% endif %}
                    {% if pending_commitments|length > 0 %}
                        {% for c in pending_commitments %}
                            <div class="panel-item commitment" data-chat="Update me on {{ c.title }}">
                                {{ c.title|default('(untitled)') }}
                                {% if c.due_date %}<span class="item-meta">Due: {{ c.due_date }}</span>{% endif %}
                            </div>
                        {% endfor %}
                    {% else %}
                        {% if drifting_commitments|length == 0 %}
                            <div class="panel-empty">No pending commitments.</div>
                        {% endif %}
                    {% endif %}
                </div>
            </div>

            {# People #}
            <div class="panel-section" id="panelPeople">
                <div class="panel-section-title">People <span class="badge" id="peopleCount">{{ people|length }}</span></div>
                <div id="peopleItems">
                    {% if people|length > 0 %}
                        {% for item in people %}
                            <div class="panel-item people" data-chat="What did {{ item.person_name }} say?">
                                {{ item.person_name }}
                                <span class="item-meta">{{ item.summary }}</span>
                            </div>
                        {% endfor %}
                    {% else %}
                        <div class="panel-empty">No messages from people.</div>
                    {% endif %}
                </div>
            </div>

            {# Triage #}
            <div class="panel-section" id="panelTriage" {% if triage|default([])|length == 0 %}style="display:none"{% endif %}>
                <div class="panel-section-title">Triage <span class="badge" id="triageCount">{{ triage|default([])|length }}</span></div>
                <div id="triageItems">
                    {% for item in triage|default([]) %}
                        <div class="panel-item triage" data-chat="Tell me about {{ item.person_name }}'s message">
                            {{ item.person_name }}
                            <span class="item-meta">{{ item.summary }}</span>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </aside>

        {# ── Chat Area ── #}
        <main class="chat-area">
            <div class="chat-header">
                <h1>{% if model %}<span class="chat-model-badge">{{ model }}</span>{% endif %}</h1>
                <div class="chat-header-actions">
                    {% if sessions|length > 0 %}
                    <details class="sessions-dropdown">
                        <summary>Sessions ({{ sessions|length }})</summary>
                        <ul class="session-list">
                            {% for s in sessions %}
                            <li><a href="#" data-session="{{ s.uuid }}">{{ s.title }}</a></li>
                            {% endfor %}
                        </ul>
                    </details>
                    {% endif %}
                    <button class="new-chat-btn" id="newChatBtn">New Chat</button>
                </div>
            </div>

            {% if sessions|length > 0 %}
            <div class="session-tabs" id="sessionTabs">
                {% for s in sessions|slice(0, 8) %}
                    <button type="button" class="session-tab" data-session-tab="{{ s.uuid }}" title="{{ s.title }}">{{ s.title }}</button>
                {% endfor %}
            </div>
            {% endif %}

            {% if not api_configured %}
            <div class="not-configured">
                Chat is not configured. Set <code>ANTHROPIC_API_KEY</code> in your environment to enable it.
            </div>
            {% endif %}

            <div class="messages" id="messages">
                <div class="empty-state" id="emptyState">
                    Start a conversation with Claudriel.
                </div>
            </div>

            <div class="input-area">
                <textarea
                    id="messageInput"
                    placeholder="Type a message..."
                    rows="1"
                    {% if not api_configured %}disabled{% endif %}
                ></textarea>
                <button id="sendBtn" {% if not api_configured %}disabled{% endif %}>Send</button>
            </div>
        </main>
    </div>

    <script>
    (function() {
        var briefFallbackUrl = {{ brief_fallback_url|json_encode|raw }};
        var initialFallbackPayload = {{ brief_fallback_payload|raw }};
        var dashboard = document.getElementById('dashboard');
        var panelToggle = document.getElementById('panelToggle');
        var messagesEl = document.getElementById('messages');
        var inputEl = document.getElementById('messageInput');
        var sendBtn = document.getElementById('sendBtn');
        var emptyState = document.getElementById('emptyState');
        var sessionTabsEl = document.getElementById('sessionTabs');
        var sessionListEl = document.querySelector('.session-list');
        var activeTenantId = {{ active_tenant_id|json_encode|raw }};
        var activeWorkspaceUuid = {{ active_workspace_uuid|json_encode|raw }};

        var sessionId = null;
        var sending = false;
        var chatSource = null;

        // ── Panel Toggle ──
        var panelKey = 'claudriel_panel_collapsed';
        var isCollapsed = localStorage.getItem(panelKey) === 'true';
        if (window.innerWidth <= 1024) isCollapsed = true;

        function updatePanel() {
            if (isCollapsed) {
                dashboard.classList.add('panel-collapsed');
                dashboard.classList.remove('panel-open');
                panelToggle.innerHTML = '&raquo;';
                panelToggle.title = 'Show context panel';
            } else {
                dashboard.classList.remove('panel-collapsed');
                dashboard.classList.add('panel-open');
                panelToggle.innerHTML = '&laquo;';
                panelToggle.title = 'Hide context panel';
            }
        }
        updatePanel();

        panelToggle.addEventListener('click', function() {
            isCollapsed = !isCollapsed;
            localStorage.setItem(panelKey, isCollapsed ? 'true' : 'false');
            updatePanel();
        });

        bindGuidanceActions(document);

        function primeChatInput(prompt) {
            if (!prompt || !inputEl || inputEl.disabled) {
                return false;
            }

            inputEl.value = prompt;
            inputEl.focus();
            inputEl.dispatchEvent(new Event('input'));

            return true;
        }

        function bindChatPrompts(root) {
            (root || document).querySelectorAll('[data-chat]').forEach(function(el) {
                if (el.dataset.boundChatPrompt === 'true') {
                    return;
                }

                el.dataset.boundChatPrompt = 'true';
                el.addEventListener('click', function() {
                    primeChatInput(this.getAttribute('data-chat'));
                });
            });
        }

        function setScheduleActionStatus(eventEl, state, label) {
            if (!eventEl) {
                return;
            }

            var statusEl = eventEl.querySelector('.timeline-event-action-status');
            if (!statusEl) {
                return;
            }

            statusEl.dataset.state = state;
            statusEl.textContent = label;

            if (state === 'pending') {
                eventEl.classList.add('is-action-pending');
                return;
            }

            eventEl.classList.remove('is-action-pending');
        }

        function bindScheduleActions(root) {
            (root || document).querySelectorAll('.timeline-event-action[data-schedule-action]').forEach(function(button) {
                if (button.dataset.boundScheduleAction === 'true') {
                    return;
                }

                button.dataset.boundScheduleAction = 'true';
                button.addEventListener('click', function(event) {
                    event.preventDefault();
                    event.stopPropagation();

                    var prompt = this.getAttribute('data-schedule-action');
                    var eventEl = this.closest('.timeline-event');
                    if (!prompt || !eventEl) {
                        return;
                    }

                    setScheduleActionStatus(eventEl, 'pending', 'Sending to chat...');
                    eventEl.querySelectorAll('.timeline-event-action').forEach(function(action) {
                        action.disabled = true;
                    });

                    sendMessage(prompt)
                        .then(function() {
                            setScheduleActionStatus(eventEl, 'success', 'Queued in chat');
                        })
                        .catch(function() {
                            setScheduleActionStatus(eventEl, 'error', 'Failed to send');
                        })
                        .finally(function() {
                            eventEl.querySelectorAll('.timeline-event-action').forEach(function(action) {
                                action.disabled = false;
                            });
                        });
                });
            });
        }

        bindChatPrompts(document);
        bindScheduleActions(document);

        // ── Workspace Selection ──
        var workspaceKey = 'claudriel_workspace';
        var selectedWorkspace = localStorage.getItem(workspaceKey);

        function updateWorkspaceSelection() {
            document.querySelectorAll('.workspace-card').forEach(function(card) {
                var uuid = card.getAttribute('data-workspace-uuid');
                if (uuid === selectedWorkspace) {
                    card.classList.add('selected');
                } else {
                    card.classList.remove('selected');
                }
            });
        }

        function formatWorkspaceActivityLabel(activityCount) {
            return activityCount === 1 ? '1 event' : activityCount + ' events';
        }

        function createWorkspaceCard(ws) {
            var activityCount = Number(ws.activity_count || 0);
            var card = document.createElement('div');
            card.className = 'workspace-card workspace-card-enter';
            card.setAttribute('data-workspace-uuid', ws.uuid || '');
            card.setAttribute('data-workspace-name', ws.name || '');
            card.innerHTML = '<div class="workspace-name">' + esc(ws.name || 'Untitled workspace') + '</div>'
                + '<div class="workspace-activity">' + esc(formatWorkspaceActivityLabel(activityCount)) + '</div>';
            return card;
        }

        function clearWorkspaceEmptyState(workspaceGrid) {
            var emptyState = workspaceGrid.querySelector('.panel-empty');
            if (emptyState) {
                emptyState.remove();
            }
        }

        function renderWorkspaceEmptyState(workspaceGrid) {
            workspaceGrid.innerHTML = '<div class="panel-empty" style="grid-column: 1/-1;">No workspaces yet.</div>';
        }

        function bindWorkspaceCards() {
            document.querySelectorAll('.workspace-card').forEach(function(card) {
                if (card.dataset.boundWorkspaceCard === 'true') {
                    return;
                }
                card.dataset.boundWorkspaceCard = 'true';
                card.addEventListener('click', function() {
                    var uuid = this.getAttribute('data-workspace-uuid');
                    var wsName = this.getAttribute('data-workspace-name');
                    if (selectedWorkspace === uuid) {
                        selectedWorkspace = null;
                        localStorage.removeItem(workspaceKey);
                    } else {
                        selectedWorkspace = uuid;
                        localStorage.setItem(workspaceKey, uuid);
                        if (inputEl && !inputEl.disabled) {
                            inputEl.value = 'Show me everything for ' + wsName + '.';
                            inputEl.focus();
                            inputEl.dispatchEvent(new Event('input'));
                        }
                    }
                    updateWorkspaceSelection();
                });
            });
        }

        function rebuildWorkspaceSidebar(workspaces) {
            var workspaceCount = document.getElementById('workspaceCount');
            var workspaceGrid = document.getElementById('workspaceGrid');

            if (!workspaceCount || !workspaceGrid || !Array.isArray(workspaces)) {
                return;
            }

            var previousCount = Number(workspaceCount.textContent || 0);
            workspaceCount.textContent = workspaces.length;
            if (previousCount !== workspaces.length) {
                workspaceCount.classList.remove('workspace-count-pulse');
                void workspaceCount.offsetWidth;
                workspaceCount.classList.add('workspace-count-pulse');
            }

            if (workspaces.length === 0) {
                Array.from(workspaceGrid.querySelectorAll('.workspace-card')).forEach(function(card) {
                    card.classList.add('workspace-card-exit-active');
                    setTimeout(function() {
                        if (card.parentNode) {
                            card.remove();
                        }
                        if (workspaceGrid.querySelectorAll('.workspace-card').length === 0) {
                            renderWorkspaceEmptyState(workspaceGrid);
                        }
                    }, 220);
                });
                if (workspaceGrid.querySelectorAll('.workspace-card').length === 0) {
                    renderWorkspaceEmptyState(workspaceGrid);
                }
                if (selectedWorkspace !== null) {
                    selectedWorkspace = null;
                    localStorage.removeItem(workspaceKey);
                }
                return;
            }

            clearWorkspaceEmptyState(workspaceGrid);

            var existingCards = Array.from(workspaceGrid.querySelectorAll('.workspace-card'));
            var existingByUuid = {};
            existingCards.forEach(function(card) {
                existingByUuid[card.getAttribute('data-workspace-uuid') || ''] = card;
            });

            var nextUuids = {};
            workspaces.forEach(function(ws) {
                nextUuids[ws.uuid || ''] = true;
            });

            existingCards.forEach(function(card) {
                var uuid = card.getAttribute('data-workspace-uuid') || '';
                if (nextUuids[uuid]) {
                    return;
                }

                card.classList.add('workspace-card-exit-active');
                setTimeout(function() {
                    if (card.parentNode) {
                        card.remove();
                    }
                    if (workspaceGrid.querySelectorAll('.workspace-card').length === 0 && workspaces.length === 0) {
                        renderWorkspaceEmptyState(workspaceGrid);
                    }
                }, 220);
            });

            workspaces.forEach(function(ws) {
                var uuid = ws.uuid || '';
                var activityCount = Number(ws.activity_count || 0);
                var existingCard = existingByUuid[uuid];

                if (!existingCard) {
                    var newCard = createWorkspaceCard(ws);
                    workspaceGrid.appendChild(newCard);
                    requestAnimationFrame(function() {
                        newCard.classList.add('workspace-card-enter-active');
                        newCard.classList.remove('workspace-card-enter');
                        setTimeout(function() {
                            newCard.classList.remove('workspace-card-enter-active');
                        }, 260);
                    });
                    return;
                }

                existingCard.setAttribute('data-workspace-name', ws.name || '');
                var nameEl = existingCard.querySelector('.workspace-name');
                var activityEl = existingCard.querySelector('.workspace-activity');
                var nextActivityLabel = formatWorkspaceActivityLabel(activityCount);
                var changed = false;

                if (nameEl && nameEl.textContent !== (ws.name || 'Untitled workspace')) {
                    nameEl.textContent = ws.name || 'Untitled workspace';
                    changed = true;
                }
                if (activityEl && activityEl.textContent !== nextActivityLabel) {
                    activityEl.textContent = nextActivityLabel;
                    changed = true;
                }

                workspaceGrid.appendChild(existingCard);
                if (changed) {
                    existingCard.classList.remove('workspace-card-refresh');
                    void existingCard.offsetWidth;
                    existingCard.classList.add('workspace-card-refresh');
                    setTimeout(function() {
                        existingCard.classList.remove('workspace-card-refresh');
                    }, 260);
                }
            });

            if (selectedWorkspace) {
                var stillExists = workspaces.some(function(ws) {
                    return (ws.uuid || '') === selectedWorkspace;
                });
                if (!stillExists) {
                    selectedWorkspace = null;
                    localStorage.removeItem(workspaceKey);
                }
            }

            bindWorkspaceCards();
            updateWorkspaceSelection();
        }

        bindWorkspaceCards();

        updateWorkspaceSelection();

        // ── Escape helper ──
        function esc(str) { var d = document.createElement('div'); d.textContent = str; return d.innerHTML; }

        // ── Thinking Indicator ──
        function showThinking() {
            if (emptyState) emptyState.style.display = 'none';
            var div = document.createElement('div');
            div.className = 'message assistant thinking-indicator';
            var label = document.createElement('div');
            label.className = 'message-label';
            label.textContent = 'Claudriel';
            div.appendChild(label);
            var content = document.createElement('div');
            content.className = 'message-content';
            content.textContent = 'Claudriel is thinking...';
            div.appendChild(content);
            messagesEl.appendChild(div);
            messagesEl.scrollTop = messagesEl.scrollHeight;
            return div;
        }

        function removeThinking() {
            var el = messagesEl.querySelector('.thinking-indicator');
            if (el) el.remove();
        }

        // ── Rich Card Rendering ──
        var cardPatterns = [
            { pattern: /Schedule/i, type: 'schedule' },
            { pattern: /Job Hunt|Job Alerts|Job Listings/i, type: 'job-hunt' },
            { pattern: /People|Messages/i, type: 'people' },
            { pattern: /Commitment|Action Items|Due/i, type: 'commitment' },
            { pattern: /Creator/i, type: 'creator' },
            { pattern: /Notification/i, type: 'notification' },
        ];

        function wrapCardsInContent(contentEl) {
            var text = contentEl.textContent || '';
            var lines = text.split('\n');
            var sections = [];
            var current = null;

            for (var i = 0; i < lines.length; i++) {
                var line = lines[i];
                var isHeader = /^#{1,3}\s/.test(line.trim()) || /^[^\w\s]/.test(line.trim());
                var matchedType = null;

                if (isHeader) {
                    for (var j = 0; j < cardPatterns.length; j++) {
                        if (cardPatterns[j].pattern.test(line)) {
                            matchedType = cardPatterns[j].type;
                            break;
                        }
                    }
                }

                if (matchedType) {
                    if (current) sections.push(current);
                    current = { type: matchedType, header: line.trim().replace(/^#+\s*/, ''), lines: [] };
                } else if (current) {
                    current.lines.push(line);
                } else {
                    sections.push({ type: null, header: null, lines: [line] });
                }
            }
            if (current) sections.push(current);

            if (sections.length <= 1 || !sections.some(function(s) { return s.type; })) return;

            var html = '';
            sections.forEach(function(section) {
                if (section.type) {
                    html += '<div class="chat-card chat-card--' + section.type + '">';
                    html += '<div class="chat-card-header">' + esc(section.header) + '</div>';
                    html += '<div class="chat-card-body">' + esc(section.lines.join('\n')) + '</div>';
                    html += '</div>';
                } else {
                    var text = section.lines.join('\n').trim();
                    if (text) html += '<p>' + esc(text) + '</p>';
                }
            });

            contentEl.innerHTML = html;
        }

        function normalizeBriefPayload(payload) {
            if (!payload || typeof payload !== 'object') {
                return null;
            }

            if (payload.briefs && typeof payload.briefs === 'object') {
                return payload.briefs;
            }

            return payload;
        }

        function formatScheduleTime(startTime, endTime) {
            if (!startTime) {
                return '';
            }

            var start = new Date(startTime);
            if (isNaN(start.getTime())) {
                return startTime;
            }

            var options = { hour: 'numeric', minute: '2-digit' };
            var label = start.toLocaleTimeString([], options);

            if (!endTime) {
                return label;
            }

            var end = new Date(endTime);
            if (isNaN(end.getTime())) {
                return label;
            }

            return label + ' - ' + end.toLocaleTimeString([], options);
        }

        function formatClock(date) {
            try {
                return date.toLocaleTimeString([], { hour: 'numeric', minute: '2-digit' });
            } catch (error) {
                return '';
            }
        }

        function formatSourceLabel(source) {
            return String(source || 'manual').replace(/-/g, ' ').replace(/\b\w/g, function(match) {
                return match.toUpperCase();
            });
        }

        function updateGuidanceStatus(container, state, message) {
            var statusEl = container ? container.querySelector('[data-guidance-status]') : null;
            if (!statusEl) {
                return;
            }

            statusEl.dataset.guidanceStatus = state;
            statusEl.dataset.state = state;
            statusEl.textContent = message;
        }

        function guidanceStatusLabel(state) {
            if (state === 'working') {
                return 'Working…';
            }
            if (state === 'complete') {
                return 'Complete';
            }
            if (state === 'failed') {
                return 'Action failed';
            }

            return 'Ready';
        }

        function postGuidanceAction(url, body) {
            return fetch(url, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Accept': 'application/json',
                    'X-CSRF-Token': document.head.querySelector('meta[name="csrf-token"]')?.content || '',
                },
                body: JSON.stringify(body || {}),
            }).then(function(response) {
                return response.json().then(function(payload) {
                    return { ok: response.ok, payload: payload };
                });
            });
        }

        function removeNotificationCard(notificationUuid) {
            var escapedUuid = typeof CSS !== 'undefined' && CSS.escape ? CSS.escape(notificationUuid) : notificationUuid;
            document.querySelectorAll('[data-notification-uuid="' + escapedUuid + '"]').forEach(function(node) {
                node.remove();
            });
        }

        function bindGuidanceActions(root) {
            (root || document).querySelectorAll('[data-guidance-dismiss]').forEach(function(button) {
                if (button.dataset.boundGuidance === 'dismiss') {
                    return;
                }
                button.dataset.boundGuidance = 'dismiss';
                button.addEventListener('click', function() {
                    var notificationUuid = this.getAttribute('data-guidance-dismiss');
                    var container = this.closest('[data-notification-uuid]');
                    updateGuidanceStatus(container, 'working', 'Dismissing…');
                    postGuidanceAction('/api/temporal-notifications/' + encodeURIComponent(notificationUuid) + '/dismiss', {
                        tenant_id: activeTenantId,
                        workspace_uuid: activeWorkspaceUuid
                    }).then(function(result) {
                        if (!result.ok) {
                            updateGuidanceStatus(container, 'error', result.payload.error || 'Dismiss failed.');
                            return;
                        }
                        removeNotificationCard(notificationUuid);
                    });
                });
            });

            (root || document).querySelectorAll('[data-guidance-snooze]').forEach(function(button) {
                if (button.dataset.boundGuidance === 'snooze') {
                    return;
                }
                button.dataset.boundGuidance = 'snooze';
                button.addEventListener('click', function() {
                    var notificationUuid = this.getAttribute('data-guidance-snooze');
                    var container = this.closest('[data-notification-uuid]');
                    updateGuidanceStatus(container, 'working', 'Snoozing…');
                    postGuidanceAction('/api/temporal-notifications/' + encodeURIComponent(notificationUuid) + '/snooze', {
                        tenant_id: activeTenantId,
                        workspace_uuid: activeWorkspaceUuid,
                        minutes: Number(this.getAttribute('data-guidance-minutes') || '15')
                    }).then(function(result) {
                        if (!result.ok) {
                            updateGuidanceStatus(container, 'error', result.payload.error || 'Snooze failed.');
                            return;
                        }
                        removeNotificationCard(notificationUuid);
                    });
                });
            });

            (root || document).querySelectorAll('[data-guidance-open]').forEach(function(button) {
                if (button.dataset.boundGuidance === 'open') {
                    return;
                }
                button.dataset.boundGuidance = 'open';
                button.addEventListener('click', function() {
                    var prompt = this.getAttribute('data-guidance-open');
                    var notificationUuid = this.getAttribute('data-guidance-notification');
                    var actionType = this.getAttribute('data-guidance-action') || 'open_chat';
                    var container = this.closest('[data-notification-uuid]');
                    updateGuidanceStatus(container, 'working', 'Opening in chat…');
                    postGuidanceAction('/api/temporal-notifications/' + encodeURIComponent(notificationUuid) + '/actions/' + encodeURIComponent(actionType), {
                        tenant_id: activeTenantId,
                        workspace_uuid: activeWorkspaceUuid,
                        state: 'working'
                    }).then(function(result) {
                        if (!result.ok) {
                            updateGuidanceStatus(container, 'error', result.payload.error || 'Open action failed.');
                            return;
                        }
                        if (prompt) {
                            sendMessage(prompt);
                        }
                        return postGuidanceAction('/api/temporal-notifications/' + encodeURIComponent(notificationUuid) + '/actions/' + encodeURIComponent(actionType), {
                            tenant_id: activeTenantId,
                            workspace_uuid: activeWorkspaceUuid,
                            state: 'complete'
                        });
                    }).then(function(result) {
                        if (result && !result.ok) {
                            updateGuidanceStatus(container, 'error', result.payload.error || 'Open action failed.');
                            return;
                        }
                        updateGuidanceStatus(container, 'complete', 'Queued in chat');
                    });
                });
            });
        }

        function renderGuidance(data) {
            var guidance = data && data.proactive_guidance ? data.proactive_guidance : { notifications: [], ambient_nudge: null };
            var notifications = Array.isArray(guidance.notifications) ? guidance.notifications : [];
            var ambient = guidance.ambient_nudge || null;
            var guidanceCount = document.getElementById('guidanceCount');
            var guidancePanel = document.getElementById('guidancePanel');

            if (guidanceCount) {
                guidanceCount.textContent = notifications.length;
            }

            if (guidancePanel) {
                if (notifications.length === 0) {
                    guidancePanel.innerHTML = '<div class="panel-empty">No live guidance right now.</div>';
                } else {
                    guidancePanel.innerHTML = notifications.map(function(notification) {
                        var primaryAction = Array.isArray(notification.actions) && notification.actions.length > 0 ? notification.actions[0] : null;
                        var primaryState = primaryAction && primaryAction.state ? primaryAction.state : 'idle';
                        return '<article class="guidance-card" data-notification-uuid="' + esc(notification.uuid) + '" data-agent-name="' + esc(notification.agent_name) + '" data-workspace-uuid="' + esc(activeWorkspaceUuid || '') + '">'
                            + '<div class="guidance-card-header"><div><div class="guidance-card-chip">' + esc(String(notification.agent_name || '').replace(/-/g, ' ')) + '</div>'
                            + '<div class="guidance-card-title">' + esc(notification.title || '') + '</div></div></div>'
                            + '<div class="guidance-card-summary">' + esc(notification.summary || '') + '</div>'
                            + '<div class="guidance-card-actions">'
                            + (primaryAction ? '<button class="guidance-button guidance-button--primary" type="button" data-guidance-open="' + esc(primaryAction.payload && primaryAction.payload.prompt ? primaryAction.payload.prompt : '') + '" data-guidance-notification="' + esc(notification.uuid) + '" data-guidance-action="' + esc(primaryAction.type || '') + '">' + esc(primaryAction.label || 'Open') + '</button>' : '')
                            + '<button class="guidance-button" type="button" data-guidance-snooze="' + esc(notification.uuid) + '" data-guidance-minutes="15">Snooze 15m</button>'
                            + '<button class="guidance-button" type="button" data-guidance-dismiss="' + esc(notification.uuid) + '">Dismiss</button>'
                            + '</div><div class="guidance-meta">' + esc(String(notification.reason_code || '').replace(/_/g, ' ')) + '</div><div class="guidance-status" data-guidance-status="' + esc(primaryState) + '" data-state="' + esc(primaryState) + '">' + esc(guidanceStatusLabel(primaryState)) + '</div></article>';
                    }).join('');
                }

                bindGuidanceActions(guidancePanel);
            }

            var scheduleItems = document.getElementById('scheduleItems');
            if (!scheduleItems) {
                return;
            }

            var timeline = scheduleItems.querySelector('.schedule-timeline');
            if (!timeline) {
                return;
            }

            var priorAmbient = timeline.querySelector('.ambient-nudge');
            if (priorAmbient) {
                priorAmbient.remove();
            }

            if (!ambient) {
                return;
            }

            var primary = Array.isArray(ambient.actions) && ambient.actions.length > 0 ? ambient.actions[0] : null;
            timeline.insertAdjacentHTML('afterbegin',
                '<div class="ambient-nudge" data-notification-uuid="' + esc(ambient.uuid) + '" data-workspace-uuid="' + esc(activeWorkspaceUuid || '') + '">'
                + '<div class="ambient-nudge-copy"><div class="ambient-nudge-eyebrow">Ambient Nudge</div><div class="ambient-nudge-title">' + esc(ambient.title || '') + '</div><div class="ambient-nudge-summary">' + esc(ambient.summary || '') + '</div></div>'
                + '<div class="ambient-nudge-actions">'
                + (primary ? '<button class="guidance-button guidance-button--primary" type="button" data-guidance-open="' + esc(primary.payload && primary.payload.prompt ? primary.payload.prompt : '') + '" data-guidance-notification="' + esc(ambient.uuid) + '" data-guidance-action="' + esc(primary.type || '') + '">' + esc(primary.label || 'Open') + '</button>' : '')
                + '</div></div>'
            );
            bindGuidanceActions(timeline);
        }

        // ── Sidebar Rebuild from Brief Data ──
        function rebuildSidebar(data) {
            data = normalizeBriefPayload(data);
            if (!data) {
                return;
            }

            renderGuidance(data);

            // Schedule
            var scheduleCount = document.getElementById('scheduleCount');
            var scheduleItems = document.getElementById('scheduleItems');
            var scheduleTimeline = data.schedule_timeline || data.schedule || [];
            if (scheduleCount && scheduleItems) {
                scheduleCount.textContent = scheduleTimeline.length;
                if (scheduleTimeline.length > 0) {
                    var nowLocal = data.time_snapshot && data.time_snapshot.local ? new Date(data.time_snapshot.local) : new Date();
                    scheduleItems.innerHTML = '<div class="schedule-timeline"><div class="schedule-now-indicator">Now · ' + esc(formatClock(nowLocal)) + '</div>'
                        + scheduleTimeline.map(function(item, index) {
                            var start = new Date(item.start_time || '');
                            var end = new Date(item.end_time || '');
                            var state = end <= nowLocal ? 'past' : (start <= nowLocal && end > nowLocal ? 'current' : 'future');
                            var expanded = state !== 'future' || index === 0 ? ' is-expanded' : '';
                            var scheduleTime = formatScheduleTime(item.start_time || '', item.end_time || '');
                            var primaryLabel = state === 'past' ? 'Capture follow-up' : 'Prep me';
                            var secondaryLabel = state === 'past' ? 'Wrap-up' : (state === 'current' ? 'Shift plan' : 'Open in chat');
                            var primaryPrompt = state === 'past'
                                ? 'Capture follow-up actions from ' + String(item.title || 'this block') + ' at ' + scheduleTime + '.'
                                : 'Prep me for ' + String(item.title || 'this block') + ' at ' + scheduleTime + '.';
                            var secondaryPrompt = state === 'past'
                                ? 'Summarize the outcome of ' + String(item.title || 'this block') + ' at ' + scheduleTime + '.'
                                : (state === 'current'
                                    ? 'Help me shift ' + String(item.title || 'this block') + ' at ' + scheduleTime + '.'
                                    : 'Tell me about ' + String(item.title || 'this block') + ' at ' + scheduleTime + '.');
                            return '<div class="timeline-event timeline-event--' + state + expanded + '" data-chat="Tell me about ' + esc(item.title) + '">'
                                + '<div class="timeline-event-head"><div class="timeline-event-title">' + esc(item.title) + '</div>'
                                + '<div class="timeline-event-time">' + esc(scheduleTime) + '</div></div>'
                                + '<div class="timeline-event-body"><div>' + esc(formatSourceLabel(item.source || 'manual')) + '</div>'
                                + '<div class="timeline-event-state ' + state + '">' + esc(state === 'current' ? 'Current block' : (state === 'future' ? 'Upcoming block' : 'Past block')) + '</div>'
                                + '<div class="timeline-event-actions">'
                                + '<button class="timeline-event-action timeline-event-action--primary" type="button" data-schedule-action="' + esc(primaryPrompt) + '">' + esc(primaryLabel) + '</button>'
                                + '<button class="timeline-event-action" type="button" data-schedule-action="' + esc(secondaryPrompt) + '">' + esc(secondaryLabel) + '</button>'
                                + '</div><div class="timeline-event-action-status" data-state="idle">Ready</div></div></div>';
                        }).join('') + '</div>';
                    bindScheduleActions(scheduleItems);
                    bindChatPrompts(scheduleItems);
                } else {
                    scheduleItems.innerHTML = '<div class="panel-empty">' + esc(data.schedule_summary || 'Your day is clear') + '</div>';
                }
            }

            // People
            var peopleCount = document.getElementById('peopleCount');
            var peopleItems = document.getElementById('peopleItems');
            if (peopleCount && peopleItems && data.people) {
                peopleCount.textContent = data.people.length;
                if (data.people.length > 0) {
                    peopleItems.innerHTML = data.people.map(function(item) {
                        return '<div class="panel-item people" data-chat="What did ' + esc(item.person_name) + ' say?">'
                            + esc(item.person_name)
                            + '<span class="item-meta">' + esc(item.summary || '') + '</span></div>';
                    }).join('');
                } else {
                    peopleItems.innerHTML = '<div class="panel-empty">No messages from people.</div>';
                }
            }

            // Triage
            var triageSection = document.getElementById('panelTriage');
            var triageCount = document.getElementById('triageCount');
            var triageItems = document.getElementById('triageItems');
            if (triageSection && triageCount && triageItems && data.triage) {
                triageCount.textContent = data.triage.length;
                if (data.triage.length > 0) {
                    triageSection.style.display = '';
                    triageItems.innerHTML = data.triage.map(function(item) {
                        return '<div class="panel-item triage" data-chat="Tell me about ' + esc(item.person_name) + '\'s message">'
                            + esc(item.person_name)
                            + '<span class="item-meta">' + esc(item.summary || '') + '</span></div>';
                    }).join('');
                } else {
                    triageSection.style.display = 'none';
                }
            }

            // Commitments
            var commitmentCount = document.getElementById('commitmentCount');
            var commitmentItems = document.getElementById('commitmentItems');
            if (commitmentCount && commitmentItems && data.commitments) {
                var drifting = data.commitments.drifting || [];
                var pending = data.commitments.pending || [];
                commitmentCount.textContent = drifting.length + pending.length;
                var html = '';
                drifting.forEach(function(c) {
                    html += '<div class="panel-item commitment drifting" data-chat="What happened with ' + esc(c.title || '(untitled)') + '?">'
                        + esc(c.title || '(untitled)') + ' <span class="drifting-label">(drifting)</span>'
                        + (c.updated_at ? '<span class="item-meta">Last: ' + esc(c.updated_at) + '</span>' : '')
                        + '</div>';
                });
                pending.forEach(function(c) {
                    html += '<div class="panel-item commitment" data-chat="Update me on ' + esc(c.title || '(untitled)') + '">'
                        + esc(c.title || '(untitled)')
                        + (c.due_date ? '<span class="item-meta">Due: ' + esc(c.due_date) + '</span>' : '')
                        + '</div>';
                });
                if (html === '') {
                    html = '<div class="panel-empty">No pending commitments.</div>';
                }
                commitmentItems.innerHTML = html;
            }

            rebuildWorkspaceSidebar(data.workspaces);

            bindChatPrompts(document);
            bindScheduleActions(document);
        }

        // ── SSE Brief Updates (with polling fallback) ──
        var briefSource = null;
        var sseRetryDelay = 30000;
        var sseMaxRetryDelay = 300000;
        var briefTimeoutMs = 30000;
        var briefTimeout = null;
        var usingFallbackTransport = true;
        var fallbackPollIntervalMs = 30000;
        var fallbackPollHandle = null;

        function clearBriefTimeout() {
            if (briefTimeout) {
                clearTimeout(briefTimeout);
                briefTimeout = null;
            }
        }

        function scheduleBriefTimeout() {
            clearBriefTimeout();
            briefTimeout = setTimeout(function() {
                switchToFallbackTransport('timeout');
            }, briefTimeoutMs);
        }

        function applyFallbackPayload(payload) {
            var normalized = normalizeBriefPayload(payload);
            if (normalized) {
                rebuildSidebar(normalized);
            }
        }

        function loadFallbackPayload() {
            return fetch(briefFallbackUrl, {
                headers: { 'Accept': 'application/json' },
                cache: 'no-store',
            }).then(function(r) {
                return r.json();
            }).then(function(data) {
                applyFallbackPayload(data);
                return data;
            }).catch(function() {
                applyFallbackPayload(initialFallbackPayload);
                return initialFallbackPayload;
            });
        }

        function switchToFallbackTransport(reason) {
            usingFallbackTransport = true;
            clearBriefTimeout();

            if (briefSource) {
                briefSource.close();
                briefSource = null;
            }

            if (!fallbackPollHandle) {
                fallbackPollHandle = setInterval(function() {
                    loadFallbackPayload().catch(function() {});
                }, fallbackPollIntervalMs);
            }

            loadFallbackPayload().finally(function() {
                if (reason !== 'default') {
                    console.warn('Brief stream switched to fallback transport:', reason);
                }
            });
        }

        function connectBriefSSE() {
            if (usingFallbackTransport) {
                return;
            }
            if (briefSource) {
                briefSource.close();
            }
            briefSource = new EventSource('/stream/brief');
            scheduleBriefTimeout();

            briefSource.addEventListener('brief-update', function(e) {
                try {
                    var data = JSON.parse(e.data);
                    applyFallbackPayload(data);
                    scheduleBriefTimeout();
                    sseRetryDelay = 30000; // Reset on success
                } catch (err) {
                    console.warn('SSE brief-update parse error:', err);
                    switchToFallbackTransport('parse-error');
                }
            });

            briefSource.addEventListener('brief-keepalive', function() {
                scheduleBriefTimeout();
            });

            briefSource.onerror = function() {
                switchToFallbackTransport('stream-error');
            };
        }

        function pollBrief() {
            loadFallbackPayload().catch(function() {});
        }

        switchToFallbackTransport('default');
        document.addEventListener('visibilitychange', function() {
            if (document.visibilityState === 'visible') {
                pollBrief();
            }
        });

        // ── Chat Functions ──
        function appendMessage(role, content) {
            if (emptyState) emptyState.style.display = 'none';

            var div = document.createElement('div');
            div.className = 'message ' + role;

            var label = document.createElement('div');
            label.className = 'message-label';
            label.textContent = role === 'user' ? 'You' : 'Claudriel';
            div.appendChild(label);

            var contentDiv = document.createElement('div');
            contentDiv.className = 'message-content';
            contentDiv.textContent = content;
            div.appendChild(contentDiv);

            messagesEl.appendChild(div);
            messagesEl.scrollTop = messagesEl.scrollHeight;
            return contentDiv;
        }

        function truncateSessionTitle(title) {
            var trimmed = String(title || '').trim();
            if (!trimmed) {
                return 'New Chat';
            }

            return trimmed.length > 48 ? trimmed.slice(0, 48).trim() + '...' : trimmed;
        }

        function updateSessionTabState() {
            if (!sessionTabsEl) return;

            sessionTabsEl.querySelectorAll('[data-session-tab]').forEach(function(tab) {
                if (tab.getAttribute('data-session-tab') === sessionId) {
                    tab.classList.add('is-active');
                } else {
                    tab.classList.remove('is-active');
                }
            });
        }

        function bindSessionTab(tab) {
            if (tab.dataset.boundSessionTab === 'true') {
                return;
            }

            tab.dataset.boundSessionTab = 'true';
            tab.addEventListener('click', function() {
                var uuid = this.getAttribute('data-session-tab');
                if (uuid) {
                    loadSession(uuid);
                }
            });
        }

        function bindSessionLink(link) {
            if (link.dataset.boundSessionLink === 'true') {
                return;
            }

            link.dataset.boundSessionLink = 'true';
            link.addEventListener('click', function(e) {
                e.preventDefault();
                loadSession(this.getAttribute('data-session'));
            });
        }

        function upsertSessionListItem(uuid, title) {
            if (!uuid) return;

            var dropdown = document.querySelector('.sessions-dropdown');
            if (!dropdown) {
                var headerActions = document.querySelector('.chat-header-actions');
                if (headerActions) {
                    dropdown = document.createElement('details');
                    dropdown.className = 'sessions-dropdown';
                    var summary = document.createElement('summary');
                    summary.textContent = 'Sessions (0)';
                    dropdown.appendChild(summary);
                    headerActions.insertBefore(dropdown, document.getElementById('newChatBtn'));
                }
            }

            if (!sessionListEl && dropdown) {
                sessionListEl = document.createElement('ul');
                sessionListEl.className = 'session-list';
                dropdown.appendChild(sessionListEl);
            }
            if (!sessionListEl) return;

            var label = truncateSessionTitle(title);
            var existingLink = null;
            sessionListEl.querySelectorAll('[data-session]').forEach(function(candidate) {
                if (!existingLink && candidate.getAttribute('data-session') === uuid) {
                    existingLink = candidate;
                }
            });

            if (existingLink) {
                existingLink.textContent = label;
                existingLink.title = title;
                if (existingLink.parentNode && existingLink.parentNode.parentNode) {
                    existingLink.parentNode.parentNode.insertBefore(existingLink.parentNode, existingLink.parentNode.parentNode.firstChild);
                }
                return;
            }

            var item = document.createElement('li');
            var link = document.createElement('a');
            link.href = '#';
            link.setAttribute('data-session', uuid);
            link.textContent = label;
            link.title = title;
            item.appendChild(link);
            sessionListEl.insertBefore(item, sessionListEl.firstChild);
            bindSessionLink(link);
            if (dropdown) {
                var summaryEl = dropdown.querySelector('summary');
                if (summaryEl) {
                    summaryEl.textContent = 'Sessions (' + sessionListEl.querySelectorAll('[data-session]').length + ')';
                }
            }
        }

        function upsertSessionTab(uuid, title, animate) {
            if (!uuid) return;

            if (!sessionTabsEl) {
                sessionTabsEl = document.createElement('div');
                sessionTabsEl.className = 'session-tabs';
                sessionTabsEl.id = 'sessionTabs';
                var chatHeader = document.querySelector('.chat-header');
                if (chatHeader && chatHeader.parentNode) {
                    chatHeader.parentNode.insertBefore(sessionTabsEl, chatHeader.nextSibling);
                }
            }

            var label = truncateSessionTitle(title);
            var existing = null;
            sessionTabsEl.querySelectorAll('[data-session-tab]').forEach(function(candidate) {
                if (!existing && candidate.getAttribute('data-session-tab') === uuid) {
                    existing = candidate;
                }
            });

            if (existing) {
                existing.textContent = label;
                existing.title = title;
                if (existing.parentNode) {
                    existing.parentNode.insertBefore(existing, existing.parentNode.firstChild);
                }
                updateSessionTabState();
                return;
            }

            var tab = document.createElement('button');
            tab.type = 'button';
            tab.className = 'session-tab' + (animate ? ' is-new' : '');
            tab.setAttribute('data-session-tab', uuid);
            tab.textContent = label;
            tab.title = title;
            sessionTabsEl.insertBefore(tab, sessionTabsEl.firstChild);
            bindSessionTab(tab);

            while (sessionTabsEl.children.length > 8) {
                sessionTabsEl.removeChild(sessionTabsEl.lastChild);
            }

            updateSessionTabState();
            upsertSessionListItem(uuid, title);
        }

        function formatProgressPhase(phase) {
            return ({
                prepare: 'Prepare',
                connect: 'Connect',
                tool: 'Tool',
                respond: 'Respond',
                finalize: 'Finalize',
                error: 'Error',
            })[phase] || 'Update';
        }

        function ensureProgressRail(messageEl) {
            var rail = messageEl.querySelector('.message-progress');
            if (!rail) {
                rail = document.createElement('div');
                rail.className = 'message-progress';
                messageEl.insertBefore(rail, messageEl.querySelector('.message-content'));
            }

            return rail;
        }

        function appendProgressSummary(messageEl, payload) {
            if (!payload || !payload.summary) return;

            var rail = ensureProgressRail(messageEl);
            var level = ['info', 'success', 'warning', 'error'].indexOf(payload.level) >= 0 ? payload.level : 'info';
            var key = String(payload.phase || '') + '|' + String(payload.summary || '');
            var lastItem = rail.lastElementChild;
            if (lastItem && lastItem.getAttribute('data-progress-key') === key) {
                return;
            }

            var item = document.createElement('div');
            item.className = 'message-progress-item is-' + level;
            item.setAttribute('data-progress-key', key);

            var phase = document.createElement('span');
            phase.className = 'progress-phase';
            phase.textContent = formatProgressPhase(payload.phase || '');
            item.appendChild(phase);

            var summary = document.createElement('span');
            summary.className = 'progress-summary';
            summary.textContent = payload.summary;
            item.appendChild(summary);

            rail.appendChild(item);
            window.requestAnimationFrame(function() {
                item.classList.add('is-visible');
            });

            while (rail.children.length > 6) {
                rail.removeChild(rail.firstChild);
            }

            messagesEl.scrollTop = messagesEl.scrollHeight;
        }

        function showError(text) {
            var div = document.createElement('div');
            div.className = 'error-message';
            div.textContent = text;
            messagesEl.appendChild(div);
            messagesEl.scrollTop = messagesEl.scrollHeight;
        }

        function sendMessage(messageOverride) {
            var message = messageOverride || inputEl.value.trim();
            if (!message) {
                return Promise.resolve(false);
            }
            if (sending) {
                return Promise.reject(new Error('busy'));
            }

            sending = true;
            sendBtn.disabled = true;
            if (!messageOverride) inputEl.value = '';
            inputEl.style.height = 'auto';

            appendMessage('user', message);
            showThinking();

            var payload = { message: message };
            if (sessionId) payload.session_id = sessionId;

            return fetch('/api/chat/send', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-CSRF-Token': document.head.querySelector('meta[name="csrf-token"]')?.content || '',
                },
                body: JSON.stringify(payload),
            })
            .then(function(resp) {
                return resp.json().then(function(data) { return { ok: resp.ok, data: data }; });
            })
            .then(function(result) {
                if (!result.ok) {
                    removeThinking();
                    showError(result.data.error || 'Something went wrong.');
                    sending = false;
                    sendBtn.disabled = false;
                    inputEl.focus();
                    throw new Error(result.data.error || 'send_failed');
                }

                sessionId = result.data.session_id;
                var messageId = result.data.message_id;
                upsertSessionTab(sessionId, message.slice(0, 60), !payload.session_id);

                if (!messageId) {
                    removeThinking();
                    var contentEl = appendMessage('assistant', result.data.response);
                    wrapCardsInContent(contentEl);
                    sending = false;
                    sendBtn.disabled = false;
                    inputEl.focus();

                    return result.data;
                }

                return new Promise(function(resolve, reject) {
                    var assistantContent = appendMessage('assistant', '');
                    var assistantMsg = assistantContent.parentElement;
                    assistantMsg.classList.add('streaming');
                    assistantMsg.style.display = 'none';
                    var assistantVisible = false;
                    var receivedToken = false;

                    function revealAssistant() {
                        if (assistantVisible) return;
                        removeThinking();
                        assistantMsg.style.display = '';
                        assistantVisible = true;
                    }

                    function finish() {
                        sending = false;
                        sendBtn.disabled = false;
                        inputEl.focus();
                    }

                    chatSource = new EventSource('/stream/chat/' + messageId);

                    chatSource.addEventListener('chat-token', function(e) {
                        try {
                            revealAssistant();
                            receivedToken = true;
                            var tokenData = JSON.parse(e.data);
                            assistantContent.textContent += tokenData.token || '';
                            messagesEl.scrollTop = messagesEl.scrollHeight;
                        } catch (err) {}
                    });

                    chatSource.addEventListener('chat-progress', function(e) {
                        try {
                            revealAssistant();
                            appendProgressSummary(assistantMsg, JSON.parse(e.data));
                        } catch (err) {}
                    });

                    chatSource.addEventListener('chat-done', function(e) {
                        chatSource.close();
                        chatSource = null;
                        var doneData = null;
                        try {
                            doneData = JSON.parse(e.data);
                        } catch (err) {}
                        if (!assistantVisible) {
                            revealAssistant();
                        }
                        if (!receivedToken && doneData && doneData.full_response) {
                            assistantContent.textContent = doneData.full_response;
                        }
                        assistantMsg.classList.remove('streaming');
                        wrapCardsInContent(assistantContent);
                        finish();
                        pollBrief();
                        resolve(result.data);
                    }, { once: true });

                    chatSource.addEventListener('chat-error', function(e) {
                        chatSource.close();
                        chatSource = null;
                        assistantMsg.classList.remove('streaming');
                        revealAssistant();
                        try {
                            var errData = JSON.parse(e.data);
                            appendProgressSummary(assistantMsg, {
                                phase: 'error',
                                summary: errData.error || 'Stream error.',
                                level: 'error'
                            });
                            showError(errData.error || 'Stream error.');
                        } catch (err) {
                            appendProgressSummary(assistantMsg, {
                                phase: 'error',
                                summary: 'Stream error.',
                                level: 'error'
                            });
                            showError('Stream error.');
                        }
                        finish();
                        reject(new Error('stream_error'));
                    }, { once: true });

                    chatSource.onerror = function() {
                        chatSource.close();
                        chatSource = null;
                        assistantMsg.classList.remove('streaming');
                        revealAssistant();
                        appendProgressSummary(assistantMsg, {
                            phase: 'error',
                            summary: 'Connection to the chat stream was interrupted.',
                            level: 'warning'
                        });
                        finish();
                        reject(new Error('stream_connection_error'));
                    };
                });
            })
            .catch(function(error) {
                if (error && (error.message === 'busy' || error.message === 'stream_error' || error.message === 'stream_connection_error' || error.message === 'send_failed')) {
                    throw error;
                }

                removeThinking();
                showError('Network error: could not reach the server.');
                sending = false;
                sendBtn.disabled = false;
                inputEl.focus();
                throw error;
            });
        }

        sendBtn.addEventListener('click', function() { sendMessage(); });

        inputEl.addEventListener('keydown', function(e) {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                sendMessage();
            }
        });

        inputEl.addEventListener('input', function() {
            this.style.height = 'auto';
            this.style.height = Math.min(this.scrollHeight, 120) + 'px';
        });

        // ── Session links ──
        function loadSession(uuid) {
            sessionId = uuid;
            updateSessionTabState();
            messagesEl.innerHTML = '';
            var loading = document.createElement('div');
            loading.className = 'empty-state';
            loading.textContent = 'Loading session...';
            messagesEl.appendChild(loading);

            // Close the dropdown
            var dropdown = document.querySelector('.sessions-dropdown');
            if (dropdown) dropdown.removeAttribute('open');

            fetch('/api/chat/sessions/' + encodeURIComponent(uuid) + '/messages')
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    messagesEl.innerHTML = '';
                    if (!data.messages || data.messages.length === 0) {
                        var empty = document.createElement('div');
                        empty.className = 'empty-state';
                        empty.textContent = 'No messages in this session.';
                        messagesEl.appendChild(empty);
                        return;
                    }
                    data.messages.forEach(function(msg) {
                        var contentEl = appendMessage(msg.role, msg.content);
                        if (msg.role === 'assistant') {
                            wrapCardsInContent(contentEl);
                        }
                    });
                })
                .catch(function() {
                    messagesEl.innerHTML = '';
                    showError('Failed to load session.');
                });
        }

        document.querySelectorAll('[data-session]').forEach(bindSessionLink);

        if (sessionTabsEl) {
            sessionTabsEl.querySelectorAll('[data-session-tab]').forEach(bindSessionTab);
        }

        document.getElementById('newChatBtn').addEventListener('click', function(e) {
            e.preventDefault();
            sessionId = null;
            updateSessionTabState();
            messagesEl.innerHTML = '';
            emptyState = document.createElement('div');
            emptyState.className = 'empty-state';
            emptyState.id = 'emptyState';
            emptyState.textContent = 'Start a conversation with Claudriel.';
            messagesEl.appendChild(emptyState);
        });

    })();
    </script>
{% endblock %}
