{% extends "base.html.twig" %}

{% block title %}Commitment Extraction Drift{% endblock %}

{% block styles %}
  .drift-page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2rem 1.25rem 3rem;
  }
  .hero, .panel {
    margin-bottom: 1rem;
  }
  .hero h1, .panel h2, .panel h3 {
    font-family: var(--font-display);
  }
  .hero p, .muted {
    color: var(--text-secondary);
  }
  .nav-link, .sender-link, .lookup-form button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 0.7rem 0.95rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-emphasis);
    color: var(--accent-blue);
    background: var(--bg-elevated);
    text-decoration: none;
    font-weight: 600;
  }
  .panel, .metric-card {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
  }
  .panel {
    padding: 1rem 1.1rem;
  }
  .metric-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
    gap: 0.85rem;
  }
  .metric-card {
    padding: 0.95rem 1rem;
  }
  .metric-label {
    color: var(--text-secondary);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .metric-value {
    margin-top: 0.35rem;
    font-family: var(--font-display);
    font-size: 1.5rem;
  }
  .drift-pill {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 186, 108, 0.28);
    background: rgba(255, 186, 108, 0.12);
    color: #ffd59a;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .lookup-form {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: end;
  }
  .lookup-form label {
    display: grid;
    gap: 0.35rem;
    flex: 1 1 260px;
  }
  .lookup-form input {
    background: rgba(15, 17, 23, 0.7);
    border: 1px solid var(--border);
    color: var(--text-primary);
    border-radius: var(--radius-md);
    padding: 0.7rem 0.8rem;
  }
  table {
    width: 100%;
    border-collapse: collapse;
  }
  th, td {
    padding: 0.7rem 0.6rem;
    text-align: left;
    border-bottom: 1px solid var(--border-subtle);
  }
  th {
    color: var(--text-secondary);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  td code {
    color: var(--accent-teal);
  }
{% endblock %}

{% block content %}
  <main class="drift-page">
    <section class="hero">
      <p><a class="nav-link" href="/audit/commitment-extraction">Back to audit dashboard</a></p>
      <h1>Extraction Confidence Drift</h1>
      <p>Compare the latest extraction-quality window against the immediately preceding window to detect confidence decay before it becomes systemic.</p>
    </section>

    <section class="panel">
      <h2>Global Drift Summary</h2>
      <p class="muted">
        Comparing {{ drift.current_window.start_date }} to {{ drift.current_window.end_date }}
        against {{ drift.previous_window.start_date }} to {{ drift.previous_window.end_date }}.
      </p>
      <p><span class="drift-pill">{{ drift.classification }}</span></p>
      <div class="metric-grid">
        <article class="metric-card">
          <div class="metric-label">Avg confidence delta</div>
          <div class="metric-value">{{ drift.delta.avg_confidence_delta > 0 ? '+' : '' }}{{ (drift.delta.avg_confidence_delta * 100)|round(1) }}%</div>
        </article>
        <article class="metric-card">
          <div class="metric-label">Low-confidence rate delta</div>
          <div class="metric-value">{{ drift.delta.low_confidence_rate_delta > 0 ? '+' : '' }}{{ (drift.delta.low_confidence_rate_delta * 100)|round(1) }}%</div>
        </article>
        <article class="metric-card">
          <div class="metric-label">Current attempts</div>
          <div class="metric-value">{{ drift.current_window.total_attempts }}</div>
        </article>
        <article class="metric-card">
          <div class="metric-label">Previous attempts</div>
          <div class="metric-value">{{ drift.previous_window.total_attempts }}</div>
        </article>
      </div>
    </section>

    <section class="panel">
      <h2>7-Day vs Previous 7-Day Deltas</h2>
      <table>
        <thead>
          <tr>
            <th>Metric</th>
            <th>Current window</th>
            <th>Previous window</th>
            <th>Delta</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Average confidence</td>
            <td>{{ (drift.current_window.average_confidence * 100)|round(1) }}%</td>
            <td>{{ (drift.previous_window.average_confidence * 100)|round(1) }}%</td>
            <td>{{ drift.delta.avg_confidence_delta > 0 ? '+' : '' }}{{ (drift.delta.avg_confidence_delta * 100)|round(1) }}%</td>
          </tr>
          <tr>
            <td>Low-confidence rate</td>
            <td>{{ (drift.current_window.low_confidence_rate * 100)|round(1) }}%</td>
            <td>{{ (drift.previous_window.low_confidence_rate * 100)|round(1) }}%</td>
            <td>{{ drift.delta.low_confidence_rate_delta > 0 ? '+' : '' }}{{ (drift.delta.low_confidence_rate_delta * 100)|round(1) }}%</td>
          </tr>
        </tbody>
      </table>
    </section>

    <section class="panel">
      <h2>Failure Category Drift</h2>
      <table>
        <thead>
          <tr>
            <th>Category</th>
            <th>Current rate</th>
            <th>Previous rate</th>
            <th>Delta</th>
          </tr>
        </thead>
        <tbody>
          {% for category in drift.delta.failure_category_distribution_delta %}
            <tr>
              <td><code>{{ category.category }}</code></td>
              <td>{{ (category.current_rate * 100)|round(1) }}%</td>
              <td>{{ (category.previous_rate * 100)|round(1) }}%</td>
              <td>{{ category.delta > 0 ? '+' : '' }}{{ (category.delta * 100)|round(1) }}%</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </section>

    <section class="panel">
      <h3>Sender Lookup</h3>
      <form class="lookup-form" method="get" action="/audit/commitment-extraction/drift">
        <label>
          <span>Sender email</span>
          <input type="email" name="sender_email" value="{{ sender_lookup }}" placeholder="sender@example.com">
        </label>
        <button type="submit">Preview sender drift</button>
      </form>

      {% if sender_drift_preview %}
        <div class="metric-grid" style="margin-top: 1rem;">
          <article class="metric-card">
            <div class="metric-label">Sender classification</div>
            <div class="metric-value">{{ sender_drift_preview.classification }}</div>
          </article>
          <article class="metric-card">
            <div class="metric-label">Avg confidence delta</div>
            <div class="metric-value">{{ sender_drift_preview.delta.avg_confidence_delta > 0 ? '+' : '' }}{{ (sender_drift_preview.delta.avg_confidence_delta * 100)|round(1) }}%</div>
          </article>
        </div>
        {% if sender_lookup_url %}
          <p style="margin-top: 1rem;"><a class="sender-link" href="{{ sender_lookup_url }}">Open sender drift detail</a></p>
        {% endif %}
      {% endif %}
    </section>
  </main>
{% endblock %}
