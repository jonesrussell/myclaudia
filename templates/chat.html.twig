{% extends "base.html.twig" %}
{% set active_nav = 'chat' %}

{% block title %}Chat — Claudriel{% endblock %}

{% block styles %}
        body {
            max-width: 720px;
            margin: 2rem auto;
            padding: 0 1.25rem;
            display: flex;
            flex-direction: column;
            min-height: calc(100vh - 4rem);
        }
        .site-nav {
            margin: -2rem calc(-50vw + 50%) 2rem;
        }
        .site-nav-inner {
            max-width: 720px;
        }

        h1 {
            font-family: var(--font-display);
            font-size: 1.75rem;
            font-weight: 700;
            letter-spacing: -0.02em;
            border-bottom: 1px solid var(--border);
            padding-bottom: 0.5rem;
            margin-bottom: 1rem;
        }

        .chat-container {
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .messages {
            flex: 1;
            overflow-y: auto;
            padding: 1rem 0;
            min-height: 300px;
            max-height: calc(100vh - 300px);
        }

        .message {
            margin-bottom: 1rem;
            padding: 0.85rem 1.1rem;
            border-radius: var(--radius-md);
            font-size: 0.9rem;
            max-width: 85%;
        }

        .message.user {
            background: var(--accent-blue);
            color: #fff;
            margin-left: auto;
            border-bottom-right-radius: 3px;
        }

        .message.assistant {
            background: var(--bg-surface);
            border: 1px solid var(--border);
            border-bottom-left-radius: 3px;
        }

        .message.assistant .message-content {
            white-space: pre-wrap;
            word-wrap: break-word;
        }

        .message.assistant .message-content p {
            margin-bottom: 0.5rem;
        }

        .message.assistant .message-content p:last-child {
            margin-bottom: 0;
        }

        .message-label {
            font-size: 0.68rem;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            margin-bottom: 0.3rem;
            color: var(--text-muted);
        }

        .message.user .message-label {
            color: rgba(255,255,255,0.6);
        }

        .input-area {
            padding: 1rem 0;
            border-top: 1px solid var(--border);
            display: flex;
            gap: 0.6rem;
        }

        .input-area textarea {
            flex: 1;
            padding: 0.7rem 0.85rem;
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            font-family: var(--font-body);
            font-size: 0.9rem;
            resize: none;
            min-height: 44px;
            max-height: 120px;
            line-height: 1.4;
            background: var(--bg-elevated);
            color: var(--text-primary);
            transition: border-color 0.2s;
        }

        .input-area textarea::placeholder {
            color: var(--text-muted);
        }

        .input-area textarea:focus {
            outline: none;
            border-color: var(--accent-blue);
            box-shadow: 0 0 0 2px rgba(91, 141, 239, 0.15);
        }

        .input-area button {
            padding: 0 1.25rem;
            background: var(--accent-blue);
            color: #fff;
            border: none;
            border-radius: var(--radius-md);
            font-size: 0.85rem;
            font-weight: 500;
            cursor: pointer;
            white-space: nowrap;
            font-family: var(--font-body);
            transition: background 0.15s;
        }

        .input-area button:hover {
            background: #4a7de0;
        }

        .input-area button:disabled {
            background: var(--bg-hover);
            color: var(--text-muted);
            cursor: not-allowed;
        }

        .empty-state {
            text-align: center;
            padding: 3rem 1rem;
            color: var(--text-muted);
            font-style: italic;
        }

        .error {
            color: #f87171;
            background: rgba(239, 68, 68, 0.1);
            border: 1px solid rgba(239, 68, 68, 0.25);
            padding: 0.6rem 0.85rem;
            border-radius: var(--radius-sm);
            margin-bottom: 1rem;
            font-size: 0.85rem;
        }

        .error code {
            background: var(--bg-hover);
            padding: 0.1rem 0.35rem;
            border-radius: 3px;
            font-size: 0.85em;
        }

        .progress-indicator {
            font-size: 0.8rem;
            color: var(--text-muted);
            padding: 0.4rem 0.85rem;
            font-style: italic;
        }

        .continuation-bar {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.75rem 1rem;
            background: var(--bg-surface);
            border: 1px solid var(--accent-blue);
            border-radius: var(--radius-md);
            margin-bottom: 1rem;
        }

        .continuation-bar .continuation-message {
            flex: 1;
            font-size: 0.85rem;
            color: var(--text-primary);
        }

        .continuation-bar .continuation-meta {
            font-size: 0.75rem;
            color: var(--text-muted);
            margin-top: 0.25rem;
        }

        .continuation-bar button {
            padding: 0.5rem 1.25rem;
            border: none;
            border-radius: var(--radius-md);
            font-size: 0.85rem;
            font-weight: 500;
            cursor: pointer;
            font-family: var(--font-body);
            white-space: nowrap;
        }

        .btn-continue {
            background: var(--accent-blue);
            color: #fff;
        }

        .btn-continue:hover {
            background: #4a7de0;
        }

        .btn-cancel {
            background: transparent;
            color: var(--text-muted);
            border: 1px solid var(--border) !important;
        }

        .btn-cancel:hover {
            background: var(--bg-hover);
        }

        .limit-reached {
            color: #f87171;
            font-size: 0.85rem;
            padding: 0.6rem 0.85rem;
            background: rgba(239, 68, 68, 0.1);
            border: 1px solid rgba(239, 68, 68, 0.25);
            border-radius: var(--radius-sm);
            margin-bottom: 1rem;
        }
{% endblock %}

{% block content %}
    <h1>Chat</h1>

    {% if not api_configured %}
        <div class="error">
            Chat is not configured. Set <code>ANTHROPIC_API_KEY</code> in your environment to enable it.
        </div>
    {% endif %}

    <div class="chat-container">
        <div class="messages" id="chatMessages">
            <div class="empty-state">Start a conversation to see messages here.</div>
        </div>

        <form class="input-area" id="chatForm">
            <textarea name="message" placeholder="Ask Claudriel…" required></textarea>
            <button type="submit">Send</button>
        </form>
    </div>

    <script>
        const form = document.getElementById('chatForm');
        const messagesEl = document.getElementById('chatMessages');
        const textarea = form.querySelector('textarea');
        let currentSessionId = null;
        let currentEventSource = null;

        function addMessage(content, role) {
            const emptyState = messagesEl.querySelector('.empty-state');
            if (emptyState) emptyState.remove();

            const msg = document.createElement('div');
            msg.className = `message ${role}`;

            const label = document.createElement('div');
            label.className = 'message-label';
            label.textContent = role === 'user' ? 'You' : 'Claudriel';

            const body = document.createElement('div');
            body.className = 'message-content';

            msg.appendChild(label);
            msg.appendChild(body);
            messagesEl.appendChild(msg);
            messagesEl.scrollTop = messagesEl.scrollHeight;

            return body;
        }

        function setInputEnabled(enabled) {
            textarea.disabled = !enabled;
            form.querySelector('button').disabled = !enabled;
            if (enabled) textarea.focus();
        }

        function removeContinuationBar() {
            const existing = messagesEl.querySelector('.continuation-bar');
            if (existing) existing.remove();
        }

        function removeLimitReached() {
            const existing = messagesEl.querySelector('.limit-reached');
            if (existing) existing.remove();
        }

        function showContinuationBar(sessionUuid, turnsConsumed, agentMessage) {
            removeContinuationBar();
            removeLimitReached();

            const bar = document.createElement('div');
            bar.className = 'continuation-bar';

            const info = document.createElement('div');
            info.innerHTML = `
                <div class="continuation-message">${escapeHtml(agentMessage)}</div>
                <div class="continuation-meta">${turnsConsumed} turns used</div>
            `;

            const continueBtn = document.createElement('button');
            continueBtn.className = 'btn-continue';
            continueBtn.textContent = 'Continue';
            continueBtn.addEventListener('click', () => handleContinue(sessionUuid));

            const cancelBtn = document.createElement('button');
            cancelBtn.className = 'btn-cancel';
            cancelBtn.textContent = 'Stop';
            cancelBtn.addEventListener('click', () => {
                removeContinuationBar();
                setInputEnabled(true);
            });

            bar.appendChild(info);
            bar.appendChild(continueBtn);
            bar.appendChild(cancelBtn);
            messagesEl.appendChild(bar);
            messagesEl.scrollTop = messagesEl.scrollHeight;
        }

        function showLimitReached() {
            removeContinuationBar();
            removeLimitReached();

            const el = document.createElement('div');
            el.className = 'limit-reached';
            el.textContent = 'Daily turn limit reached. Please try again tomorrow.';
            messagesEl.appendChild(el);
            messagesEl.scrollTop = messagesEl.scrollHeight;
            setInputEnabled(true);
        }

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        function removeProgressIndicator() {
            const existing = messagesEl.querySelector('.progress-indicator');
            if (existing) existing.remove();
        }

        function showProgress(summary) {
            removeProgressIndicator();
            const el = document.createElement('div');
            el.className = 'progress-indicator';
            el.textContent = summary;
            messagesEl.appendChild(el);
            messagesEl.scrollTop = messagesEl.scrollHeight;
        }

        function streamResponse(messageId) {
            if (currentEventSource) {
                currentEventSource.close();
            }

            const contentEl = addMessage('', 'assistant');
            let fullText = '';

            const es = new EventSource(`/stream/chat/${messageId}`);
            currentEventSource = es;

            es.addEventListener('chat-token', (e) => {
                const data = JSON.parse(e.data);
                fullText += data.token || '';
                contentEl.textContent = fullText;
                messagesEl.scrollTop = messagesEl.scrollHeight;
            });

            es.addEventListener('chat-progress', (e) => {
                const data = JSON.parse(e.data);
                showProgress(data.summary || 'Working...');
            });

            es.addEventListener('chat-done', (e) => {
                es.close();
                currentEventSource = null;
                removeProgressIndicator();
                const data = JSON.parse(e.data);
                if (data.full_response && !fullText) {
                    contentEl.textContent = data.full_response;
                }
                setInputEnabled(true);
            });

            es.addEventListener('chat-needs-continuation', (e) => {
                es.close();
                currentEventSource = null;
                removeProgressIndicator();
                const data = JSON.parse(e.data);
                showContinuationBar(
                    data.session_uuid || currentSessionId,
                    data.turns_consumed || 0,
                    data.message || 'The agent needs more turns to complete this task.'
                );
            });

            es.addEventListener('chat-error', (e) => {
                es.close();
                currentEventSource = null;
                removeProgressIndicator();
                const data = JSON.parse(e.data);
                contentEl.textContent = `Error: ${data.error || 'Unknown error'}`;
                setInputEnabled(true);
            });

            es.onerror = () => {
                es.close();
                currentEventSource = null;
                removeProgressIndicator();
                if (!fullText) {
                    contentEl.textContent = 'Connection lost. Please try again.';
                }
                setInputEnabled(true);
            };
        }

        async function handleContinue(sessionUuid) {
            removeContinuationBar();
            showProgress('Continuing...');

            try {
                const res = await fetch(`/api/internal/session/${sessionUuid}/continue`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                });

                if (res.status === 429) {
                    removeProgressIndicator();
                    showLimitReached();
                    return;
                }

                if (!res.ok) {
                    removeProgressIndicator();
                    addMessage(`Error: could not continue (${res.status})`, 'assistant');
                    setInputEnabled(true);
                    return;
                }

                const data = await res.json();
                removeProgressIndicator();

                // Re-send the last user message to get a new stream with continued=true
                const continueRes = await fetch('/api/chat/send', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        message: '[continue]',
                        session_id: sessionUuid,
                        continued: true,
                    }),
                });

                if (!continueRes.ok) {
                    addMessage('Error: could not continue the conversation.', 'assistant');
                    setInputEnabled(true);
                    return;
                }

                const continueData = await continueRes.json();
                currentSessionId = continueData.session_id;
                streamResponse(continueData.message_id);
            } catch (err) {
                removeProgressIndicator();
                addMessage('Network error while continuing. Please try again.', 'assistant');
                setInputEnabled(true);
            }
        }

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            const text = textarea.value.trim();
            if (!text) return;

            addMessage(text, 'user');
            textarea.value = '';
            setInputEnabled(false);

            try {
                const body = { message: text };
                if (currentSessionId) body.session_id = currentSessionId;

                const res = await fetch('/api/chat/send', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(body),
                });

                if (!res.ok) {
                    addMessage(`Error: ${res.status} ${res.statusText}`, 'assistant');
                    setInputEnabled(true);
                    return;
                }

                const data = await res.json();
                currentSessionId = data.session_id;
                streamResponse(data.message_id);
            } catch (err) {
                addMessage('Network error. Please try again.', 'assistant');
                setInputEnabled(true);
            }
        });
    </script>
{% endblock %}
