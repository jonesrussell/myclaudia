{% extends "base.html.twig" %}

{% block title %}Model Update Batches{% endblock %}

{% block styles %}
  .batch-page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2rem 1.25rem 3rem;
  }
  .panel {
    background: linear-gradient(180deg, rgba(33,35,47,0.98) 0%, rgba(24,26,36,0.98) 100%);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.18);
    padding: 1rem 1.1rem;
    margin-top: 1rem;
  }
  .panel h1, .panel h2 {
    font-family: var(--font-display);
  }
  table {
    width: 100%;
    border-collapse: collapse;
  }
  th, td {
    padding: 0.7rem 0.6rem;
    text-align: left;
    border-bottom: 1px solid var(--border-subtle);
    vertical-align: top;
  }
  th {
    color: var(--text-secondary);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
{% endblock %}

{% block content %}
  <main class="batch-page">
    <section class="panel">
      <h1>Model Update Batches</h1>
      <p>This placeholder view can render saved model update batches, their metadata, and links to the stored JSON artifacts.</p>
    </section>

    <section class="panel">
      <h2>Recent Batches</h2>
      <table>
        <thead>
          <tr>
            <th>Batch</th>
            <th>Generated</th>
            <th>Window</th>
            <th>Samples</th>
            <th>Failure Rate</th>
          </tr>
        </thead>
        <tbody>
          {% for batch in batches|default([]) %}
            <tr>
              <td><a href="/ai/model-update-batch/{{ batch.batch_id|url_encode }}.json">{{ batch.batch_id }}</a></td>
              <td>{{ batch.metadata.generated_at }}</td>
              <td>{{ batch.metadata.window_days }} days</td>
              <td>{{ batch.metadata.total_samples }}</td>
              <td>{{ (batch.metadata.failure_rate * 100)|round(1) }}%</td>
            </tr>
          {% else %}
            <tr>
              <td colspan="5">No stored batches yet.</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </section>
  </main>
{% endblock %}
