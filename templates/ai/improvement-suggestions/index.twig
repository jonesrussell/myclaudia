{% extends "base.html.twig" %}

{% block title %}Extraction Improvement Suggestions{% endblock %}

{% block styles %}
  .suggestions-page {
    max-width: 1120px;
    margin: 0 auto;
    padding: 2rem 1.25rem 3rem;
  }
  .panel, .metric-card {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
  }
  .panel {
    padding: 1rem 1.1rem;
    margin-top: 1rem;
  }
  .hero h1, .panel h2 {
    font-family: var(--font-display);
  }
  .hero p, .muted {
    color: var(--text-secondary);
  }
  .nav-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 0.7rem 0.95rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-emphasis);
    color: var(--accent-blue);
    background: var(--bg-elevated);
    text-decoration: none;
    font-weight: 700;
  }
  .metric-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 0.85rem;
    margin-top: 1rem;
  }
  .metric-card {
    padding: 0.95rem 1rem;
  }
  .metric-label {
    color: var(--text-secondary);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .metric-value {
    margin-top: 0.35rem;
    font-family: var(--font-display);
    font-size: 1.55rem;
  }
  table {
    width: 100%;
    border-collapse: collapse;
  }
  th, td {
    padding: 0.7rem 0.6rem;
    text-align: left;
    border-bottom: 1px solid var(--border-subtle);
    vertical-align: top;
  }
  th {
    color: var(--text-secondary);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .severity-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 78px;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.74rem;
    letter-spacing: 0.05em;
  }
  .severity-pill.high {
    color: #ffd0d0;
    background: rgba(181, 52, 52, 0.18);
    border: 1px solid rgba(240, 96, 96, 0.32);
  }
  .severity-pill.medium {
    color: #ffe2b3;
    background: rgba(177, 110, 16, 0.18);
    border: 1px solid rgba(241, 180, 78, 0.28);
  }
  .severity-pill.low {
    color: #ccf3dd;
    background: rgba(26, 122, 73, 0.18);
    border: 1px solid rgba(87, 199, 138, 0.28);
  }
{% endblock %}

{% block content %}
  <main class="suggestions-page">
    {% include 'components/status-bar.twig' with { data: statusBarData } %}
    <section class="hero">
      <p><a class="nav-link" href="/audit/commitment-extraction">Back to audit dashboard</a></p>
      <h1>Extraction Improvement Suggestions</h1>
      <p>Claudriel synthesizes recent self-assessment, drift, hotspot, and export signals into concrete next actions for the extraction system.</p>
    </section>

    <section class="panel">
      <h2>Improvement Summary</h2>
      <p class="muted">{{ summary }}</p>
      <div class="metric-grid">
        <article class="metric-card">
          <div class="metric-label">Review Window</div>
          <div class="metric-value">{{ report.window_days }} days</div>
        </article>
        <article class="metric-card">
          <div class="metric-label">Self-Assessment Score</div>
          <div class="metric-value">{{ report.assessment.overall_score }}/100</div>
        </article>
        <article class="metric-card">
          <div class="metric-label">Drift Classification</div>
          <div class="metric-value">{{ report.drift.classification }}</div>
        </article>
      </div>
    </section>

    <section class="panel">
      <h2>Suggestions Table</h2>
      <table>
        <thead>
          <tr>
            <th>Category</th>
            <th>Severity</th>
            <th>Rationale</th>
            <th>Recommended Action</th>
          </tr>
        </thead>
        <tbody>
          {% for suggestion in report.suggestions %}
            <tr>
              <td><code>{{ suggestion.category }}</code></td>
              <td><span class="severity-pill {{ suggestion.severity }}">{{ suggestion.severity }}</span></td>
              <td>{{ suggestion.rationale }}</td>
              <td>{{ suggestion.recommended_action }}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </section>
  </main>
{% endblock %}
