{% extends "base.html.twig" %}

{% block title %}Extraction Self-Assessment{% endblock %}

{% block styles %}
  .assessment-page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2rem 1.25rem 3rem;
  }
  .panel, .metric-card {
    background: linear-gradient(180deg, rgba(33,35,47,0.98) 0%, rgba(24,26,36,0.98) 100%);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.18);
  }
  .panel {
    padding: 1rem 1.1rem;
    margin-top: 1rem;
  }
  .hero h1, .panel h2, .panel h3 {
    font-family: var(--font-display);
  }
  .hero p, .muted {
    color: var(--text-secondary);
  }
  .metric-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 0.85rem;
    margin-top: 1rem;
  }
  .metric-card {
    padding: 0.95rem 1rem;
  }
  .metric-label {
    color: var(--text-secondary);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .metric-value {
    margin-top: 0.35rem;
    font-family: var(--font-display);
    font-size: 1.55rem;
  }
  .score-pill, .nav-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 0.7rem 0.95rem;
    border-radius: var(--radius-md);
    border: 1px solid rgba(124, 196, 255, 0.3);
    color: var(--accent-blue);
    background: rgba(29, 91, 142, 0.12);
    text-decoration: none;
    font-weight: 700;
  }
  .action-row {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 0.9rem;
  }
  .inline-form {
    margin: 0;
  }
  .action-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 0.7rem 0.95rem;
    border-radius: var(--radius-md);
    border: 1px solid rgba(124, 196, 255, 0.3);
    color: var(--accent-blue);
    background: rgba(29, 91, 142, 0.12);
    text-decoration: none;
    font-weight: 700;
    cursor: pointer;
  }
  table {
    width: 100%;
    border-collapse: collapse;
  }
  th, td {
    padding: 0.7rem 0.6rem;
    text-align: left;
    border-bottom: 1px solid var(--border-subtle);
    vertical-align: top;
  }
  th {
    color: var(--text-secondary);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  ul {
    margin: 0;
    padding-left: 1.2rem;
  }
  li + li {
    margin-top: 0.45rem;
  }
  td code {
    color: var(--accent-teal);
  }
{% endblock %}

{% block content %}
  <main class="assessment-page">
    {% include 'components/status-bar.twig' with { data: statusBarData } %}
    <section class="hero">
      <div class="action-row">
        <a class="nav-link" href="/audit/commitment-extraction">Back to audit dashboard</a>
        <form class="inline-form" method="post" action="/ai/model-update-batch">
          <input type="hidden" name="days" value="{{ assessment.window_days }}">
          <button class="action-button" type="submit">Generate Model Update Batch</button>
        </form>
      </div>
      <h1>Extraction Self-Assessment</h1>
      <p>Claudriel evaluates recent extraction quality, highlights the most damaging failure patterns, and identifies the senders most likely to need model attention next.</p>
    </section>

    <section class="panel">
      <h2>Overall Score</h2>
      <p><span class="score-pill">{{ assessment.overall_score }}/100</span></p>
      <div class="metric-grid">
        <article class="metric-card">
          <div class="metric-label">Drift Classification</div>
          <div class="metric-value">{{ assessment.drift_summary.classification }}</div>
        </article>
        <article class="metric-card">
          <div class="metric-label">Avg confidence delta</div>
          <div class="metric-value">{{ assessment.drift_summary.delta.avg_confidence_delta > 0 ? '+' : '' }}{{ (assessment.drift_summary.delta.avg_confidence_delta * 100)|round(1) }}%</div>
        </article>
        <article class="metric-card">
          <div class="metric-label">Low-confidence rate delta</div>
          <div class="metric-value">{{ assessment.drift_summary.delta.low_confidence_rate_delta > 0 ? '+' : '' }}{{ (assessment.drift_summary.delta.low_confidence_rate_delta * 100)|round(1) }}%</div>
        </article>
      </div>
    </section>

    <section class="panel">
      <h2>Self-Assessment Summary</h2>
      <p class="muted">{{ focus_summary }}</p>
    </section>

    <section class="panel">
      <h2>Failure Category Distribution</h2>
      <table>
        <thead>
          <tr>
            <th>Category</th>
            <th>Count</th>
            <th>Rate</th>
          </tr>
        </thead>
        <tbody>
          {% for category in assessment.failure_category_distribution %}
            <tr>
              <td><code>{{ category.category }}</code></td>
              <td>{{ category.count }}</td>
              <td>{{ (category.rate * 100)|round(1) }}%</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </section>

    <section class="panel">
      <h2>Recommended Focus Areas</h2>
      <ul>
        {% for area in assessment.recommended_focus_areas %}
          <li>{{ area }}</li>
        {% endfor %}
      </ul>
    </section>

    <section class="panel">
      <h2>Sender Hotspots</h2>
      <table>
        <thead>
          <tr>
            <th>Sender</th>
            <th>Classification</th>
            <th>Confidence drop</th>
            <th>Low-rate delta</th>
            <th>Total attempts</th>
          </tr>
        </thead>
        <tbody>
          {% for hotspot in assessment.sender_hotspots %}
            <tr>
              <td><code>{{ hotspot.sender }}</code></td>
              <td>{{ hotspot.classification }}</td>
              <td>{{ (hotspot.avg_confidence_drop * 100)|round(1) }}%</td>
              <td>{{ hotspot.low_confidence_rate_delta > 0 ? '+' : '' }}{{ (hotspot.low_confidence_rate_delta * 100)|round(1) }}%</td>
              <td>{{ hotspot.total_attempts }}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </section>
  </main>
{% endblock %}
