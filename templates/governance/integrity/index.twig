{% extends "base.html.twig" %}

{% block title %}Codified Context Integrity{% endblock %}

{% block styles %}
  .integrity-page {
    max-width: 1120px;
    margin: 0 auto;
    padding: 2rem 1.25rem 3rem;
  }
  .panel {
    background: linear-gradient(180deg, rgba(33,35,47,0.98) 0%, rgba(24,26,36,0.98) 100%);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.18);
    padding: 1rem 1.1rem;
    margin-top: 1rem;
  }
  .panel h1, .panel h2 {
    font-family: var(--font-display);
  }
  .muted {
    color: var(--text-secondary);
  }
  table {
    width: 100%;
    border-collapse: collapse;
  }
  th, td {
    padding: 0.7rem 0.6rem;
    text-align: left;
    border-bottom: 1px solid var(--border-subtle);
    vertical-align: top;
  }
  th {
    color: var(--text-secondary);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .severity-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 78px;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.74rem;
    letter-spacing: 0.05em;
  }
  .severity-pill.critical {
    color: #ffd0d0;
    background: rgba(181, 52, 52, 0.18);
    border: 1px solid rgba(240, 96, 96, 0.32);
  }
  .severity-pill.warning {
    color: #ffe2b3;
    background: rgba(177, 110, 16, 0.18);
    border: 1px solid rgba(241, 180, 78, 0.28);
  }
  .severity-pill.info {
    color: #ccf3dd;
    background: rgba(26, 122, 73, 0.18);
    border: 1px solid rgba(87, 199, 138, 0.28);
  }
{% endblock %}

{% block content %}
  <main class="integrity-page">
    {% include 'components/status-bar.twig' with { data: statusBarData } %}
    <section class="panel">
      <h1>Codified Context Integrity Report</h1>
      <p class="muted">{{ summary }}</p>
      <p class="muted">Generated at {{ generated_at }}</p>
    </section>

    <section class="panel">
      <h2>Issue Table</h2>
      <table>
        <thead>
          <tr>
            <th>Issue</th>
            <th>Severity</th>
            <th>Message</th>
            <th>Context</th>
          </tr>
        </thead>
        <tbody>
          {% for issue in issues %}
            <tr>
              <td><code>{{ issue.code }}</code></td>
              <td><span class="severity-pill {{ classifications[issue.code]|default('info') }}">{{ classifications[issue.code]|default('info') }}</span></td>
              <td>{{ issue.message }}</td>
              <td><code>{{ issue.context }}</code></td>
            </tr>
          {% else %}
            <tr>
              <td colspan="4">No integrity issues detected.</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </section>
  </main>
{% endblock %}
