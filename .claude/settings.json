{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bin/check-milestones",
            "show_output": true
          },
          {
            "type": "command",
            "command": "tools/drift-detector.sh 20 2>&1",
            "show_output": true
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "claudriel-specs": {
      "command": "node",
      "args": ["tools/spec-retrieval/server.js"],
      "cwd": "."
    },
    "claudia-memory": {
      "command": "node",
      "args": ["tools/memory-mcp/server.js"],
      "cwd": ".",
      "env": {
        "CLAUDRIEL_API_URL": "http://localhost:8088",
        "CLAUDRIEL_API_KEY": "${CLAUDRIEL_API_KEY}"
      }
    },
    "waaseyaa": {
      "command": "node",
      "args": ["vendor/waaseyaa/mcp/server.js"],
      "cwd": "."
    }
  }
}
