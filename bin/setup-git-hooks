#!/usr/bin/env bash

set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
hooks_path="$repo_root/bin/git-hooks"

chmod +x "$hooks_path/pre-push"
git -C "$repo_root" config core.hooksPath bin/git-hooks

echo "Configured git hooks at bin/git-hooks"
echo "pre-push will run: composer lint, composer analyse, composer test"
