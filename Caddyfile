# claudriel.northcloud.one - included via import in main /etc/caddy/Caddyfile
# Deploy path: ~/claudriel, current release: ~/claudriel/current

claudriel.northcloud.one {
  tls {
    issuer acme {
    }
  }

  # Keep browsers on HTTP/2 or HTTP/1.1 for SSE; QUIC has been flaky for EventSource.
  header Alt-Svc "clear"

  root * /home/deployer/claudriel/current/public

  @not_stream {
    not path /stream/*
  }
  encode @not_stream gzip zstd

  @stream {
    path /stream/*
  }
  handle @stream {
    header Cache-Control "no-cache"
    header X-Accel-Buffering "no"
    php_fastcgi unix//run/php/php8.4-fpm.sock {
      resolve_root_symlink
    }
  }

  # Admin SPA — HTML entry point must always revalidate so browsers
  # pick up new _nuxt/* hashed filenames after each deploy.
  @admin_html {
    path /admin /admin/ /admin/index.html
  }
  handle @admin_html {
    header Cache-Control "no-cache"
    file_server
  }

  # Admin SPA — hashed JS/CSS bundles are safe to cache forever.
  @admin_assets {
    path /admin/_nuxt/*
  }
  handle @admin_assets {
    header Cache-Control "public, max-age=31536000, immutable"
    file_server
  }

  @images {
    path /images/*
  }
  handle @images {
    header Cache-Control "public, max-age=31536000, immutable"
    file_server
  }

  @ico {
    path *.ico
  }
  handle @ico {
    header Cache-Control "public, max-age=31536000, immutable"
    file_server
  }

  file_server
  php_fastcgi * unix//run/php/php8.4-fpm.sock {
    resolve_root_symlink
  }

  log {
    output file /home/deployer/claudriel/log/access.log {
      mode 0644
    }
  }

  handle_errors {
    @404 {
      expression {http.error.status_code} == 404
    }
    rewrite @404 /404.html
    file_server {
      root /var/deployer
    }
  }
}
