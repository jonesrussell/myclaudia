# Claudriel Configuration
# Copy to .env and fill in values

# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------

# Runtime environment: development | staging | production
CLAUDRIEL_ENV=production

# Default tenant identifier (multi-tenancy key)
CLAUDRIEL_DEFAULT_TENANT=default

# IANA timezone used by schedule normalizer (e.g. America/Toronto)
CLAUDRIEL_TIMEZONE=America/Toronto

# Absolute path to file storage directory (tokens, sessions, brief cache)
# CLAUDRIEL_STORAGE=/var/lib/claudriel/storage

# Project root override (auto-detected when unset)
# CLAUDRIEL_PROJECT_ROOT=/srv/claudriel

# Workspace root directory for repo clones (defaults to <project>/workspaces)
# CLAUDRIEL_WORKSPACE_ROOT=/srv/claudriel/workspaces

# App base URL (used for OAuth redirects and email verification links)
CLAUDRIEL_APP_URL=https://claudriel.northcloud.one

# ---------------------------------------------------------------------------
# API
# ---------------------------------------------------------------------------

# API authentication key for ingestion endpoint
CLAUDRIEL_API_KEY=change-me-to-a-random-string

# Bearer token for MCP server authentication (external Claude Code sessions)
# Falls back to CLAUDRIEL_API_KEY if unset
MCP_BEARER_TOKEN=

# REQUIRED: Base URL the agent subprocess uses to call back to the PHP API.
# Local dev: http://localhost:8088 (must match your PHP dev server port)
# Staging: https://claudriel.northcloud.one
# Production: https://claudriel.ai
CLAUDRIEL_API_URL=http://localhost:8088

# Ingest endpoint URL (used by agent system prompt; defaults to http://caddy/api/ingest)
# CLAUDRIEL_INGEST_URL=https://claudriel.northcloud.one/api/ingest

# ---------------------------------------------------------------------------
# Anthropic (AI / Chat)
# ---------------------------------------------------------------------------

# Anthropic API key (for chat interface and AI pipelines)
ANTHROPIC_API_KEY=sk-ant-...

# Anthropic model ID
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---------------------------------------------------------------------------
# Agent subprocess
# ---------------------------------------------------------------------------

# Internal API HMAC auth secret (min 32 random bytes)
AGENT_INTERNAL_SECRET=change-me-to-a-random-string-at-least-32-bytes

# Path to agent Python entry point (default: <project>/agent/main.py)
# AGENT_PATH=/srv/claudriel/agent/main.py

# Python venv for agent (default: <project>/agent/.venv)
# AGENT_VENV=/srv/claudriel/agent/.venv

# Agent Docker image (set on production; leave empty for local dev venv)
# AGENT_DOCKER_IMAGE=claudriel-agent

# ---------------------------------------------------------------------------
# Google OAuth (Gmail, Calendar, Drive)
# ---------------------------------------------------------------------------

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://claudriel.northcloud.one/auth/google/callback

# ---------------------------------------------------------------------------
# GitHub (issue orchestrator, optional)
# ---------------------------------------------------------------------------

GITHUB_REPOSITORY=jonesrussell/claudriel
GITHUB_TOKEN=
GITHUB_OWNER=jonesrussell
GITHUB_REPO=claudriel

# ---------------------------------------------------------------------------
# Email delivery (SendGrid)
# ---------------------------------------------------------------------------

SENDGRID_API_KEY=
CLAUDRIEL_MAIL_FROM_EMAIL=noreply@claudriel.ai
CLAUDRIEL_MAIL_FROM_NAME=Claudriel

# ---------------------------------------------------------------------------
# Database (used by PdoDatabase — typically set via docker-compose)
# ---------------------------------------------------------------------------

# DATABASE_URL=mysql://user:pass@127.0.0.1:3306/claudriel

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------

# CORS origins for admin SPA (comma-separated, merged with dev defaults)
WAASEYAA_CORS_ORIGINS=https://claudriel.ai,https://claudriel.northcloud.one
